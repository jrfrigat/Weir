@* Weir brand mark: the SVG form of favicon.svg (three hollow "database" rings on top, a cyan->blue "W"
   flowing down, two "gateway rail" bars merging at the bottom). This is app branding, the on-surface
   sibling of favicon.svg / assets/banner.svg - not a restyled Flare component, so it is authored art
   like the favicon rather than a Flare gap. Strokes are a touch heavier than the favicon so the mark
   still reads at app-bar size, and there is no background badge: the glyph sits directly on the app-bar
   surface, the way the previous single-glyph icon did. The gradient and mask ids are namespaced so they
   never collide with the app's other inline SVG. *@
<svg width="@Size" height="@Size" viewBox="0 0 32 32" role="img" aria-label="Weir"
     style="flex:none;display:block;">
    <defs>
        <linearGradient id="weirMarkEdge" x1="0" y1="0" x2="32" y2="32" gradientUnits="userSpaceOnUse">
            <stop offset="0" stop-color="#4fd6c9" />
            <stop offset="1" stop-color="#4ea1ff" />
        </linearGradient>
        <mask id="weirMarkRingCut">
            <rect width="32" height="32" fill="white" />
            <g fill="black">
                <circle cx="8.5" cy="10.8" r="2.9" />
                <circle cx="16" cy="10.8" r="2.9" />
                <circle cx="23.5" cy="10.8" r="2.9" />
            </g>
            <rect x="9" y="17.8" width="22" height="6" fill="black" />
        </mask>
        <mask id="weirMarkBarCut">
            <rect width="32" height="32" fill="black" />
            <polygon points="10.4,17.3 21.6,17.3 19.5,21.2 12.5,21.2" fill="white" />
        </mask>
    </defs>

    @* W flowing down from the database rings; masked so it stops cleanly at the rings and the rail. *@
    <g fill="none" stroke="url(#weirMarkEdge)" mask="url(#weirMarkRingCut)"
       stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M8.5 10.8 L12.8 19 L16 12.8 L19.2 19 L23.5 10.8" />
    </g>

    @* Gateway rail: two bars clipped to a narrowing trapezoid, so the databases merge to one surface. *@
    <g fill="none" stroke="url(#weirMarkEdge)" stroke-width="1.2" mask="url(#weirMarkBarCut)"
       stroke-linecap="round">
        <path d="M9 18.6 L23 18.6" />
        <path d="M9 20.2 L23 20.2" />
    </g>

    @* Database rings (top of each W arm). *@
    <g fill="none" stroke="#4fd6c9" stroke-width="0.9" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="8.5" cy="10.8" r="1.7" />
        <circle cx="16" cy="10.8" r="1.7" />
        <circle cx="23.5" cy="10.8" r="1.7" />
    </g>
</svg>

@code {
    /// <summary>CSS length for the square mark (width and height), for example "1.6rem". Defaults to 1.5rem.</summary>
    [Parameter]
    public string Size { get; set; } = "1.5rem";
}
