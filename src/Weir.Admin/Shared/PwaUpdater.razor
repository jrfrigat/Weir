@* Surfaces a newly deployed build as a Flare snackbar toast (Weir's Command Center design), driven by
   Flare's IVersionCheckService in service-worker mode. Flare registers the service worker, polls the
   deployed asset manifest and raises NewVersionAvailable; this component only renders the notice and
   wires the "Update" action to the service. Renders no markup. *@
@implements IDisposable
@inject ISnackbarService Snackbar
@inject IVersionCheckService VersionCheck

@code {
    /// <summary>Whether the update toast has already been shown, so a repeated signal does not stack toasts.</summary>
    private bool _shown;

    /// <summary>Subscribes to version-check notifications and starts the polling loop.</summary>
    protected override void OnInitialized()
    {
        VersionCheck.NewVersionAvailable += OnNewVersionAsync;
        VersionCheck.Start();
    }

    /// <summary>
    /// Raised by the version-check service when a newer deployed build is detected. Shows one persistent,
    /// actionable snackbar; the action applies the waiting worker and reloads onto the new build.
    /// </summary>
    /// <param name="info">The current and newly detected versions.</param>
    /// <returns>A task that completes once the toast has been shown on the UI thread.</returns>
    private Task OnNewVersionAsync(VersionCheckInfo info) =>
        InvokeAsync(() =>
        {
            if (_shown)
            {
                return;
            }

            _shown = true;
            // Persistent (durationMs: 0) info toast with an Update action, rendered by FlareSnackbarProvider
            // in the app's theme - the Command Center popup, not a bespoke banner.
            Snackbar.Show("A new version of Weir Admin is available.", SnackbarSeverity.Info, 0, "Update", ApplyUpdateAsync, true);
        });

    /// <summary>Applies the waiting service worker (which triggers a one-time reload onto the new build).</summary>
    /// <returns>A task that completes once the apply has been requested.</returns>
    private async Task ApplyUpdateAsync() => await VersionCheck.ApplyUpdateAsync();

    /// <summary>Unsubscribes from version-check notifications; the service itself is owned by DI.</summary>
    public void Dispose() => VersionCheck.NewVersionAvailable -= OnNewVersionAsync;
}
