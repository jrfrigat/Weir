    /// <summary>Confirms, then deletes an endpoint and reloads the list.</summary>
    /// <param name="endpoint">The endpoint to delete.</param>
    private async Task DeleteAsync(EndpointDefinition endpoint)
    {
        var confirmed = await Dialog.ConfirmAsync(
            "Delete endpoint?",
            $"Delete {endpoint.HttpMethod} /api/{endpoint.Route}? This cannot be undone.",
            "Delete", "Cancel");
        if (confirmed != true)
        {
            return;
        }

        await Api.DeleteEndpointAsync(endpoint.Id);
        await LoadAsync();
    }

    private void AddParameter() => _editing!.Parameters.Add(new ParamEditModel());

    /// <summary>Reads the object's parameters from the database and replaces the parameter list.</summary>
    private async Task DiscoverParametersAsync()
    {
        if (_editing is null || string.IsNullOrWhiteSpace(_editing.ConnectionName) || string.IsNullOrWhiteSpace(_editing.ObjectName))
        {
            _discoverError = "Set the connection and object name first.";
            return;
        }

        _discovering = true;
        _discoverError = null;
        try
        {
            var discovered = await Api.GetDbParametersAsync(_editing.ConnectionName, _editing.Schema, _editing.ObjectName);
            if (discovered is not null)
            {
                _editing.Parameters.Clear();
                foreach (var descriptor in discovered)
                {
                    var model = new ParamEditModel
                    {
                        Name = descriptor.Name,
                        Source = ParameterSource.Body,
                        Direction = descriptor.Direction,
                        DbType = descriptor.DbType,
                        Size = descriptor.Size,
                        Precision = descriptor.Precision,
                        Scale = descriptor.Scale,
                        TypeName = descriptor.TypeName,
                    };
                    if (descriptor.TableColumns is not null)
                    {
                        foreach (var column in descriptor.TableColumns)
                        {
                            model.Columns.Add(new ColumnEditModel { Name = column.Name, DbType = column.DbType, Size = column.Size });
                        }
                    }

                    _editing.Parameters.Add(model);
                }
            }
        }
        catch (Exception ex)
        {
            _discoverError = ex.Message;
        }

        _discovering = false;
    }

    private async Task SyncAllAsync()
    {
        _syncBusy = true;
        var results = await Api.SyncAllEndpointsAsync();
        _notice = results is null ? "Nothing to sync." : $"Synced {results.Count} endpoint(s).";
        _exportUrl = null;
        _openApiUrl = null;
        _syncBusy = false;
        await LoadAsync();
    }

    private async Task SyncOneAsync(Guid id)
    {
        _syncBusy = true;
        var result = await Api.SyncEndpointAsync(id);
        _notice = result is null ? "Nothing to sync." : "Synced: " + ChangeSummary(result);
        _exportUrl = null;
        _openApiUrl = null;
        _syncBusy = false;
        await LoadAsync();
    }

    private static string ChangeSummary(EndpointSyncResult result)
    {
        if (!string.IsNullOrEmpty(result.Message))
        {
            return result.Message;
        }

        var parts = new List<string>();
        if (result.Added.Count > 0) parts.Add("added " + string.Join(", ", result.Added));
        if (result.Updated.Count > 0) parts.Add("updated " + string.Join(", ", result.Updated));
        if (result.Removed.Count > 0) parts.Add("removed " + string.Join(", ", result.Removed));
        return parts.Count == 0 ? "no changes" : string.Join("; ", parts);
    }

    private async Task BuildOpenApiAsync()
    {
        _openApiBusy = true;
        var json = await Api.GetOpenApiAsync(FilterKeyId, string.IsNullOrEmpty(_filterScope) ? null : _filterScope);
        _openApiUrl = "data:application/json;charset=utf-8," + Uri.EscapeDataString(json);
        _exportUrl = null;
        _notice = IsFiltered ? "OpenAPI document ready (filtered)." : "OpenAPI document ready.";
        _openApiBusy = false;
    }

    private void Export()
    {
        var json = JsonSerializer.Serialize(FilteredEndpoints, new JsonSerializerOptions { WriteIndented = true });
        _exportUrl = "data:application/json;charset=utf-8," + Uri.EscapeDataString(json);
        _openApiUrl = null;
        _notice = IsFiltered ? $"Export ready ({FilteredEndpoints.Count} filtered endpoint(s))." : "Export ready.";
    }

    private async Task ImportAsync(InputFileChangeEventArgs args)
    {
        _notice = null;
        try
        {
            await using var stream = args.File.OpenReadStream(5 * 1024 * 1024);
            var endpoints = await JsonSerializer.DeserializeAsync<List<EndpointDefinition>>(stream, new JsonSerializerOptions(JsonSerializerDefaults.Web));
            if (endpoints is { Count: > 0 })
            {
                var imported = await Api.ImportEndpointsAsync(endpoints);
                _notice = $"Imported {imported} endpoint(s).";
                await LoadAsync();
            }
            else
            {
                _notice = "No endpoints found in the file.";
            }
        }
        catch (Exception ex)
        {
            _notice = "Import failed: " + ex.Message;
        }
    }

