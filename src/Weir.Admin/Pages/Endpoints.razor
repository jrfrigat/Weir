    // ----- Edit models ----------------------------------------------------------------------------

    private sealed class EndpointEditModel
    {
        public Guid Id { get; set; }
        public string Route { get; set; } = string.Empty;
        public string HttpMethod { get; set; } = "POST";
        public string ConnectionName { get; set; } = string.Empty;
        public DbObjectType ObjectType { get; set; } = DbObjectType.StoredProcedure;
        public string Schema { get; set; } = "dbo";
        public string ObjectName { get; set; } = string.Empty;
        public ResultMode ResultMode { get; set; } = ResultMode.MultiRow;
        public int? CommandTimeoutSeconds { get; set; }
        public bool Enabled { get; set; } = true;
        public bool SuppressMessages { get; set; }
        public bool LogEnabled { get; set; } = true;
        public bool LogParameters { get; set; }
        public bool LogResult { get; set; }
        public int? SlowThresholdPercent { get; set; }
        public string? Description { get; set; }
        public bool CacheEnabled { get; set; }
        public int CacheTtlSeconds { get; set; } = 60;
        public HashSet<string> CacheVaryBy { get; } = new(StringComparer.OrdinalIgnoreCase);
        public bool CacheVaryByApiKey { get; set; }
        public HashSet<string> Scopes { get; } = new(StringComparer.Ordinal);
        public List<ParamEditModel> Parameters { get; } = [];

        public static EndpointEditModel From(EndpointDefinition endpoint)
        {
            var model = new EndpointEditModel
            {
                Id = endpoint.Id,
                Route = endpoint.Route,
                HttpMethod = endpoint.HttpMethod,
                ConnectionName = endpoint.ConnectionName,
                ObjectType = endpoint.ObjectType,
                Schema = endpoint.Schema,
                ObjectName = endpoint.ObjectName,
                ResultMode = endpoint.ResultMode,
                CommandTimeoutSeconds = endpoint.CommandTimeoutSeconds,
                Enabled = endpoint.Enabled,
                SuppressMessages = endpoint.SuppressMessages,
                LogEnabled = endpoint.Logging.Enabled,
                LogParameters = endpoint.Logging.LogParameters,
                LogResult = endpoint.Logging.LogResult,
                SlowThresholdPercent = endpoint.Logging.SlowThresholdPercent,
                Description = endpoint.Description,
                CacheEnabled = endpoint.Cache.Enabled,
                CacheTtlSeconds = endpoint.Cache.TtlSeconds,
                CacheVaryByApiKey = endpoint.Cache.VaryByApiKey,
            };

            foreach (var scope in endpoint.RequiredScopes)
            {
                model.Scopes.Add(scope);
            }

            foreach (var varyBy in endpoint.Cache.VaryByParameters)
            {
                model.CacheVaryBy.Add(varyBy);
            }

            foreach (var parameter in endpoint.Parameters)
            {
                model.Parameters.Add(ParamEditModel.From(parameter));
            }

            return model;
        }

        public EndpointDefinition ToDefinition() => new()
        {
            Id = Id,
            Route = Route.Trim(),
            HttpMethod = HttpMethod,
            ConnectionName = ConnectionName.Trim(),
            ObjectType = ObjectType,
            Schema = string.IsNullOrWhiteSpace(Schema) ? "dbo" : Schema.Trim(),
            ObjectName = ObjectName.Trim(),
            ResultMode = ResultMode,
            CommandTimeoutSeconds = CommandTimeoutSeconds,
            Enabled = Enabled,
            SuppressMessages = SuppressMessages,
            Logging = new EndpointLogging
            {
                Enabled = LogEnabled,
                LogParameters = LogParameters,
                LogResult = LogResult,
                SlowThresholdPercent = SlowThresholdPercent,
            },
            Description = string.IsNullOrWhiteSpace(Description) ? null : Description,
            Cache = new CachePolicy
            {
                Enabled = CacheEnabled,
                TtlSeconds = CacheTtlSeconds,
                // Only keep vary-by names that still match a defined parameter, so a renamed or removed
                // parameter cannot leave a dangling cache-key name (which would disable caching).
                VaryByParameters = CacheVaryBy.Where(name => Parameters.Any(p => string.Equals(p.Name, name, StringComparison.OrdinalIgnoreCase))).ToList(),
                VaryByApiKey = CacheVaryByApiKey,
            },
            RequiredScopes = Scopes.ToList(),
            Parameters = Parameters.Select(parameter => parameter.ToParameter()).ToList(),
        };
    }

    private sealed class ParamEditModel
    {
        public string Name { get; set; } = string.Empty;
        public string? DbParameterName { get; set; }
        public ParameterSource Source { get; set; } = ParameterSource.Body;
        public Weir.Contracts.ParameterDirection Direction { get; set; } = Weir.Contracts.ParameterDirection.Input;
        public WeirDbType DbType { get; set; } = WeirDbType.String;
        public bool Required { get; set; }
        public int? Size { get; set; }
        public byte? Precision { get; set; }
        public byte? Scale { get; set; }
        public string? TypeName { get; set; }
        public object? DefaultValue { get; set; }
        public string? ValidationRegex { get; set; }
        public string? HeaderName { get; set; }
        public string? ClaimType { get; set; }
        public List<ColumnEditModel> Columns { get; } = [];

        public static ParamEditModel From(EndpointParameter parameter)
        {
            var model = new ParamEditModel
            {
                Name = parameter.Name,
                DbParameterName = parameter.DbParameterName,
                Source = parameter.Source,
                Direction = parameter.Direction,
                DbType = parameter.DbType,
                Required = parameter.Required,
                Size = parameter.Size,
                Precision = parameter.Precision,
                Scale = parameter.Scale,
                TypeName = parameter.TypeName,
                DefaultValue = parameter.DefaultValue,
                ValidationRegex = parameter.ValidationRegex,
                HeaderName = parameter.HeaderName,
                ClaimType = parameter.ClaimType,
            };

            if (parameter.TableColumns is not null)
            {
                foreach (var column in parameter.TableColumns)
                {
                    model.Columns.Add(ColumnEditModel.From(column));
                }
            }

            return model;
        }

        public EndpointParameter ToParameter() => new()
        {
            Name = Name.Trim(),
            DbParameterName = string.IsNullOrWhiteSpace(DbParameterName) ? null : DbParameterName.Trim(),
            Source = Source,
            Direction = Direction,
            DbType = DbType,
            Required = Required,
            Size = Size,
            Precision = Precision,
            Scale = Scale,
            TypeName = string.IsNullOrWhiteSpace(TypeName) ? null : TypeName.Trim(),
            DefaultValue = DefaultValue,
            ValidationRegex = ValidationRegex,
            HeaderName = HeaderName,
            ClaimType = ClaimType,
            TableColumns = DbType == WeirDbType.Structured && Columns.Count > 0
                ? Columns.Select((column, index) => column.ToColumn(index)).ToList()
                : null,
        };
    }

    private sealed class ColumnEditModel
    {
        public string Name { get; set; } = string.Empty;
        public WeirDbType DbType { get; set; } = WeirDbType.String;
        public int? Size { get; set; }

        public static ColumnEditModel From(TvpColumn column) =>
            new() { Name = column.Name, DbType = column.DbType, Size = column.Size };

        public TvpColumn ToColumn(int ordinal) =>
            new() { Name = Name.Trim(), DbType = DbType, Size = Size, Ordinal = ordinal };
    }
}
