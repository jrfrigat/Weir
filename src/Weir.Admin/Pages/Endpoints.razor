    /// <summary>Loads the database object list for the selected connection (best-effort).</summary>
    private async Task LoadObjectsAsync()
    {
        _selectedObject = null;
        _selectedParameters = null;
        _objectsError = null;
        if (string.IsNullOrEmpty(_dbConnection))
        {
            _objects = null;
            return;
        }

        try
        {
            _objects = await Api.GetDbObjectsAsync(_dbConnection) ?? [];
        }
        catch (Exception ex)
        {
            _objectsError = ex.Message;
            _objects = null;
        }
    }

    /// <summary>Selects the clicked database object and loads its parameters into the inspector.</summary>
    /// <param name="obj">The clicked object row.</param>
    private async Task OnObjectRowClick(DbObjectDescriptor obj)
    {
        _selectedObject = obj;
        _selectedParameters = null;
        try
        {
            _selectedParameters = await Api.GetDbParametersAsync(_dbConnection, obj.Schema, obj.Name) ?? [];
        }
        catch (Exception ex)
        {
            _objectsError = ex.Message;
            _selectedParameters = [];
        }
    }

    /// <summary>Opens the editor pre-filled from a database object, then discovers its parameters.</summary>
    /// <param name="obj">The source object.</param>
    private async Task CreateFromObjectAsync(DbObjectDescriptor obj)
    {
        _editing = new EndpointEditModel
        {
            ConnectionName = _dbConnection,
            Schema = obj.Schema,
            ObjectName = obj.Name,
            ObjectType = obj.ObjectType,
            Route = obj.Name.ToLowerInvariant(),
            HttpMethod = obj.ObjectType == DbObjectType.StoredProcedure ? "POST" : "GET",
        };
        await DiscoverParametersAsync();
    }

