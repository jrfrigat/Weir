    /// <summary>Opens the test drawer for an endpoint.</summary>
    private void StartTest(EndpointDefinition endpoint)
    {
        _testing = endpoint;
        _testResponse = null;
        _testRaw = false;
        _testValues.Clear();
        _testRows.Clear();
        _testInputParameters = endpoint.Parameters
            .Where(p => p.Direction is Weir.Contracts.ParameterDirection.Input or Weir.Contracts.ParameterDirection.InputOutput && p.Source != ParameterSource.Const)
            .ToList();
        foreach (var parameter in _testInputParameters)
        {
            _testValues[parameter.Name] = parameter.DefaultValue?.ToString();
        }
    }

    private void CloseTest() => _testing = null;

    /// <summary>Toggles raw-JSON mode, seeding the raw body from the form values when enabled.</summary>
    private void ToggleRaw(bool on)
    {
        _testRaw = on;
        if (_testRaw)
        {
            _testRawBody = BuildTestBody();
        }
    }

    /// <summary>The type/source hint shown under a test-console input.</summary>
    private static string TestParamHint(EndpointParameter parameter) =>
        parameter.DbType + (parameter.Source != ParameterSource.Body ? " - " + parameter.Source : "");

    private string GetTestValue(string name) => _testValues.TryGetValue(name, out var value) ? value ?? string.Empty : string.Empty;

    private void SetTestValue(string name, string? value) => _testValues[name] = value;

    private bool GetTestBool(string name) => string.Equals(GetTestValue(name), "true", StringComparison.OrdinalIgnoreCase);

    private void SetTestBool(string name, bool on) => SetTestValue(name, on ? "true" : "false");

    private List<Dictionary<string, string?>> TestRows(EndpointParameter parameter)
    {
        if (!_testRows.TryGetValue(parameter.Name, out var rows))
        {
            rows = [];
            _testRows[parameter.Name] = rows;
        }

        return rows;
    }

    private void AddTestRow(EndpointParameter parameter) => TestRows(parameter).Add(new Dictionary<string, string?>(StringComparer.OrdinalIgnoreCase));

    private static string GetCell(Dictionary<string, string?> row, string column) => row.TryGetValue(column, out var value) ? value ?? string.Empty : string.Empty;

    private static void SetCell(Dictionary<string, string?> row, string column, string? value) => row[column] = value;

    private static string InputType(WeirDbType type) => type switch
    {
        WeirDbType.Byte or WeirDbType.Int16 or WeirDbType.Int32 or WeirDbType.Int64
            or WeirDbType.Decimal or WeirDbType.Double or WeirDbType.Single => "number",
        WeirDbType.Date => "date",
        WeirDbType.DateTime or WeirDbType.DateTimeOffset => "datetime-local",
        WeirDbType.Time => "time",
        _ => "text",
    };

    /// <summary>Builds the JSON request body from the form values, coercing to JSON types.</summary>
    private string BuildTestBody()
    {
        var obj = new JsonObject();
        foreach (var parameter in _testInputParameters)
        {
            if (parameter.DbType == WeirDbType.Structured)
            {
                if (!_testRows.TryGetValue(parameter.Name, out var rows) || rows.Count == 0)
                {
                    continue;
                }

                var array = new JsonArray();
                foreach (var row in rows)
                {
                    var rowObject = new JsonObject();
                    foreach (var column in parameter.TableColumns ?? [])
                    {
                        rowObject[column.Name] = Coerce(column.DbType, GetCell(row, column.Name));
                    }

                    array.Add(rowObject);
                }

                obj[parameter.Name] = array;
            }
            else
            {
                var value = GetTestValue(parameter.Name);
                if (string.IsNullOrEmpty(value))
                {
                    continue;
                }

                obj[parameter.Name] = Coerce(parameter.DbType, value);
            }
        }

        return obj.ToJsonString(new JsonSerializerOptions { WriteIndented = true });
    }

    /// <summary>Coerces a string field value to the JSON node matching a database type.</summary>
    private static JsonNode? Coerce(WeirDbType type, string value)
    {
        if (string.IsNullOrEmpty(value))
        {
            return null;
        }

        switch (type)
        {
            case WeirDbType.Boolean:
                return JsonValue.Create(bool.TryParse(value, out var b) && b);
            case WeirDbType.Byte:
            case WeirDbType.Int16:
            case WeirDbType.Int32:
            case WeirDbType.Int64:
                return long.TryParse(value, NumberStyles.Integer, CultureInfo.InvariantCulture, out var l) ? JsonValue.Create(l) : JsonValue.Create(value);
            case WeirDbType.Decimal:
            case WeirDbType.Double:
            case WeirDbType.Single:
                return double.TryParse(value, NumberStyles.Any, CultureInfo.InvariantCulture, out var d) ? JsonValue.Create(d) : JsonValue.Create(value);
            case WeirDbType.Json:
                try { return JsonNode.Parse(value); }
                catch (JsonException) { return JsonValue.Create(value); }
            default:
                return JsonValue.Create(value);
        }
    }

    private async Task SendTestAsync()
    {
        if (_testing is null)
        {
            return;
        }

        _testBusy = true;
        var body = _testRaw ? _testRawBody : BuildTestBody();
        var raw = await Api.InvokeEndpointAsync(_testing.Id, body);
        _testResponse = PrettyJson(raw);
        _testBusy = false;
    }

    private static string PrettyJson(string raw)
    {
        try
        {
            using var document = JsonDocument.Parse(raw);
            return JsonSerializer.Serialize(document, new JsonSerializerOptions { WriteIndented = true });
        }
        catch (JsonException)
        {
            return raw;
        }
    }

