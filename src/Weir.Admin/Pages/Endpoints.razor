@page "/endpoints"
@attribute [Authorize]
@using System.Globalization
@using System.Text.Json
@using System.Text.Json.Nodes
@inject WeirApiClient Api
@inject IDialogService Dialog
@inject NavigationManager Nav

<FlareStack Gap="FlareSpacing.Medium">
    <PageHeader Title="endpoints" Description="HTTP routes mapped to stored procedures and functions">
        <Actions>
            <FlareButton Variant="ButtonVariant.Outlined" Size="ButtonSize.Sm" OnClick="SyncAllAsync" Loading="_syncBusy">Sync all</FlareButton>
            <label style="position:relative;display:inline-flex">
                <FlareButton Variant="ButtonVariant.Outlined" Size="ButtonSize.Sm">Import</FlareButton>
                <InputFile OnChange="ImportAsync" accept=".json" style="position:absolute;inset:0;opacity:0;cursor:pointer" />
            </label>
            <FlareButton Variant="ButtonVariant.Outlined" Size="ButtonSize.Sm" OnClick="Export">Export</FlareButton>
            <FlareButton Variant="ButtonVariant.Outlined" Size="ButtonSize.Sm" OnClick="BuildOpenApiAsync" Loading="_openApiBusy">OpenAPI</FlareButton>
            <FlareButton Variant="ButtonVariant.Filled" Color="FlareColor.Primary" Size="ButtonSize.Sm" OnClick="NewEndpoint">New endpoint</FlareButton>
        </Actions>
    </PageHeader>

    @if (_notice is not null)
    {
        <FlareStack Row Align="FlareAlignItems.Center" Gap="FlareSpacing.Small">
            <FlareText Typo="TypographyScale.BodySmall" Color="FlareColor.OnSurfaceVariant">@_notice</FlareText>
            @* Plain anchors: the download targets are data: URLs, which Flare's href-safety check
               rejects (it would render them as about:blank). *@
            @if (_exportUrl is not null)
            {
                <a href="@_exportUrl" download="weir-endpoints.json" style="color:var(--flare-color-primary)">download endpoints.json</a>
            }
            @if (_openApiUrl is not null)
            {
                <a href="@_openApiUrl" download="weir-openapi.json" style="color:var(--flare-color-primary)">download openapi.json</a>
            }
        </FlareStack>
    }

    <FlareTabs ActiveIndex="_epTabIndex" ActiveIndexChanged="OnTabChangedAsync">
        <FlareTab Label="Endpoints">
            @if (_endpoints is null)
            {
                <FlareText Color="FlareColor.OnSurfaceVariant">Loading...</FlareText>
            }
            else if (_endpoints.Count == 0)
            {
                <FlareEmptyState Title="No endpoints yet" Description="Create one, or map a database object from the Database tab.">
                    <Icon><FlareIcon Name="api" /></Icon>
                </FlareEmptyState>
            }
            else
            {
                <FlareStack Row Align="FlareAlignItems.End" Gap="FlareSpacing.Small" Wrap="true">
                    <FlareText Typo="TypographyScale.LabelMedium" Mono="true" Color="FlareColor.OnSurfaceVariant" Style="letter-spacing:.1em;align-self:center;">// FILTER</FlareText>
                    <FlareSelect TValue="string" Label="Required scope" Size="FieldSize.Sm" Value="_filterScope" ValueChanged="OnFilterScopeChanged" Items="ScopeFilterOptions" ItemLabel="ScopeFilterLabel" Style="min-width:12rem;" />
                    <FlareSelect TValue="string" Label="Reachable by key" Size="FieldSize.Sm" Value="_filterKeyId" ValueChanged="OnFilterKeyChanged" Items="KeyFilterOptions" ItemLabel="KeyFilterLabel" Style="min-width:14rem;" />
                    @if (IsFiltered)
                    {
                        <FlareText Typo="TypographyScale.LabelSmall" Color="FlareColor.OnSurfaceVariant" Style="align-self:center;">showing @FilteredEndpoints.Count of @_endpoints.Count - Export and OpenAPI honour this filter</FlareText>
                        <FlareButton Variant="ButtonVariant.Text" Size="ButtonSize.Sm" OnClick="ClearFilters">Clear</FlareButton>
                    }
                </FlareStack>
                <FlareDataGrid Items="@FilteredEndpoints" Dense="true" Striped="true" Hoverable="true" FilterMode="DataGridFilterMode.Menu">
                    <ToolbarContent><FlareDataGridQuickFilter Placeholder="Filter..." /></ToolbarContent>
                    <Columns>
                        <FlareColumn TItem="EndpointDefinition" Title="Status">
                            <Template><FlareChip Size="ChipSize.Sm" Variant="ChipVariant.Filled" Color="@(context.Enabled ? FlareColor.Success : FlareColor.Default)" Label="@(context.Enabled ? "Enabled" : "Disabled")" /></Template>
                        </FlareColumn>
                        <FlareColumn TItem="EndpointDefinition" Title="Method" Field="@(e => (object?)e.HttpMethod)" Sortable="true">
                            <Template><FlareText Element="span" Mono="true" Weight="FontWeight.Bold" Color="@MethodColor(context.HttpMethod)">@context.HttpMethod</FlareText></Template>
                        </FlareColumn>
                        <FlareColumn TItem="EndpointDefinition" Title="Route" Field="@(e => (object?)e.Route)" Sortable="true" Filterable="true">
                            <Template><FlareText Element="span" Mono="true">/api/@context.Route</FlareText></Template>
                        </FlareColumn>
                        <FlareColumn TItem="EndpointDefinition" Title="Connection" Field="@(e => (object?)e.ConnectionName)" Sortable="true" Filterable="true" />
                        <FlareColumn TItem="EndpointDefinition" Title="Object" Field="@(e => (object?)(e.Schema + "." + e.ObjectName))" Sortable="true" Filterable="true" />
                        <FlareColumn TItem="EndpointDefinition" Title="Type" Field="@(e => (object?)ObjectTypeLabel(e.ObjectType))" Sortable="true" />
                        <FlareColumn TItem="EndpointDefinition" Title="Params" Field="@(e => (object?)e.Parameters.Count)" Align="ColumnAlign.End" />
                        <FlareColumn TItem="EndpointDefinition" Title="Actions" Align="ColumnAlign.End">
                            <Template>
                                <FlareStack Row Gap="FlareSpacing.XSmall" Justify="FlareJustifyContent.End">
                                    <FlareButton Variant="ButtonVariant.Text" Size="ButtonSize.Sm" Color="FlareColor.Primary" OnClick="@(() => StartTest(context))">Test</FlareButton>
                                    <FlareButton Variant="ButtonVariant.Text" Size="ButtonSize.Sm" OnClick="@(() => OpenLogs(context))">Logs</FlareButton>
                                    <FlareButton Variant="ButtonVariant.Text" Size="ButtonSize.Sm" OnClick="@(() => Edit(context))">Edit</FlareButton>
                                    <FlareButton Variant="ButtonVariant.Text" Size="ButtonSize.Sm" OnClick="@(() => SyncOneAsync(context.Id))">Sync</FlareButton>
                                    <FlareButton Variant="ButtonVariant.Text" Size="ButtonSize.Sm" Color="FlareColor.Error" OnClick="@(() => DeleteAsync(context))">Delete</FlareButton>
                                </FlareStack>
                            </Template>
                        </FlareColumn>
                    </Columns>
                </FlareDataGrid>
            }
        </FlareTab>
        <FlareTab Label="Database">
            <FlareStack Gap="FlareSpacing.Small">
                <FlareStack Row Align="FlareAlignItems.End" Gap="FlareSpacing.Small">
                    <FlareSelect TValue="string" Label="Connection" Value="_dbConnection" ValueChanged="SetDbConnectionAsync" Items="@ConnectionNames" ItemLabel="ProviderLabel" />
                    <FlareButton Variant="ButtonVariant.Outlined" Size="ButtonSize.Sm" OnClick="OnConnectionChangedAsync">Refresh</FlareButton>
                </FlareStack>
                @if (_objectsError is not null)
                {
                    <FlareAlert Severity="AlertSeverity.Warning">Objects not browsable on this connection (@_objectsError).</FlareAlert>
                }
                <FlareStack Row Gap="FlareSpacing.Medium" Align="FlareAlignItems.Start" Wrap="true">
                    <div style="flex:2 1 26rem;min-width:0;">
                        @if (_objects is null)
                        {
                            <FlareText Color="FlareColor.OnSurfaceVariant">Loading...</FlareText>
                        }
                        else if (_objects.Count == 0)
                        {
                            <FlareText Color="FlareColor.OnSurfaceVariant">No objects found on this connection.</FlareText>
                        }
                        else
                        {
                            <FlareDataGrid TItem="DbObjectDescriptor" Items="@_objects" Dense="true" Striped="true" Hoverable="true" RowClick="OnObjectRowClick">
                                <Columns>
                                    <FlareColumn TItem="DbObjectDescriptor" Title="Schema" Field="@(o => (object?)o.Schema)" Sortable="true" Filterable="true" />
                                    <FlareColumn TItem="DbObjectDescriptor" Title="Object" Field="@(o => (object?)o.Name)" Sortable="true" Filterable="true">
                                        <Template><FlareText Element="span" Mono="true">@context.Name</FlareText></Template>
                                    </FlareColumn>
                                    <FlareColumn TItem="DbObjectDescriptor" Title="Type" Field="@(o => (object?)ObjectTypeLabel(o.ObjectType))" Sortable="true" />
                                    <FlareColumn TItem="DbObjectDescriptor" Title="Endpoint" Align="ColumnAlign.End">
                                        <Template>
                                            @{
                                                var mapped = EndpointsForObject(context.Schema, context.Name);
                                            }
                                            @if (mapped.Count == 0)
                                            {
                                                <FlareChip Size="ChipSize.Sm" Variant="ChipVariant.Outlined" Color="FlareColor.Default" Label="none" />
                                            }
                                            else
                                            {
                                                <FlareStack Row Gap="FlareSpacing.XSmall" Justify="FlareJustifyContent.End" Wrap="true">
                                                    @foreach (var mappedEndpoint in mapped)
                                                    {
                                                        <FlareTooltip Content="@($"{mappedEndpoint.HttpMethod} /api/{mappedEndpoint.Route}")" Arrow="true">
                                                            <FlareChip Size="ChipSize.Sm" Variant="ChipVariant.Filled" Color="FlareColor.Success" OnClick="@(() => Edit(mappedEndpoint))">
                                                                <FlareText Element="span" Mono="true" Weight="FontWeight.Bold" Color="@MethodColor(mappedEndpoint.HttpMethod)">@mappedEndpoint.HttpMethod</FlareText>
                                                                <FlareText Element="span" Mono="true">&nbsp;/@mappedEndpoint.Route</FlareText>
                                                            </FlareChip>
                                                        </FlareTooltip>
                                                    }
                                                </FlareStack>
                                            }
                                        </Template>
                                    </FlareColumn>
                                </Columns>
                            </FlareDataGrid>
                        }
                    </div>
                    <FlareCard Variant="CardVariant.Outlined" Style="flex:1 1 20rem;min-width:18rem;">
                        @if (_selectedObject is null)
                        {
                            <FlareText Color="FlareColor.OnSurfaceVariant" Typo="TypographyScale.BodySmall">Select an object to inspect its parameters, then create an endpoint pre-filled from it.</FlareText>
                        }
                        else
                        {
                            <FlareStack Gap="FlareSpacing.Small">
                                <div>
                                    <FlareText Mono="true">@_selectedObject.Schema.@_selectedObject.Name</FlareText>
                                    <FlareText Typo="TypographyScale.LabelSmall" Color="FlareColor.OnSurfaceVariant" Mono="true">@ObjectTypeLabel(_selectedObject.ObjectType) - @(_selectedParameters?.Count ?? 0) parameters</FlareText>
                                </div>
                                @if (_selectedParameters is null)
                                {
                                    <FlareText Color="FlareColor.OnSurfaceVariant">Loading...</FlareText>
                                }
                                else
                                {
                                    <FlareDescriptionList>
                                        @foreach (var parameter in _selectedParameters)
                                        {
                                            <FlareDescriptionItem>
                                                <LabelContent>
                                                    <FlareStack Row Align="FlareAlignItems.Center" Gap="FlareSpacing.XSmall">
                                                        <FlareText Element="span" Mono="true">@parameter.Name</FlareText>
                                                        <FlareChip Size="ChipSize.Sm" Variant="ChipVariant.Outlined" Label="@parameter.Direction.ToString()" />
                                                    </FlareStack>
                                                </LabelContent>
                                                <ChildContent><FlareText Element="span" Mono="true" Color="FlareColor.OnSurfaceVariant">@TypeLabel(parameter.DbType, parameter.TypeName, parameter.Size)</FlareText></ChildContent>
                                            </FlareDescriptionItem>
                                        }
                                    </FlareDescriptionList>
                                }
                                <FlareButton Variant="ButtonVariant.Filled" Color="FlareColor.Primary" FullWidth="true" OnClick="@(() => CreateFromObjectAsync(_selectedObject))">Create endpoint from this object</FlareButton>
                            </FlareStack>
                        }
                    </FlareCard>
                </FlareStack>
            </FlareStack>
        </FlareTab>
    </FlareTabs>
</FlareStack>

@* ===== Editor drawer ===== *@
<FlareDrawer Open="@(_editing is not null)" OpenChanged="@(open => { if (!open) CancelEdit(); })" Anchor="DrawerAnchor.Right" Width="44rem" Variant="DrawerVariant.Temporary">
    <Header><FlareText Typo="TypographyScale.TitleMedium">@(_editing is { Id: var id } && id != Guid.Empty ? "Edit endpoint" : "New endpoint")</FlareText></Header>
    <ChildContent>
        @if (_editing is not null)
        {
            <FlareStack Gap="FlareSpacing.Medium">
                <FlareGrid Columns="2" Gap="FlareSpacing.Small">
                    <FlareCol Span="1"><FlareSelect TValue="string" Label="Method" Size="FieldSize.Sm" @bind-Value="_editing.HttpMethod" Items="_methods" /></FlareCol>
                    <FlareCol Span="1"><FlareField Label="Route" Size="FieldSize.Sm" @bind-Value="_editing.Route" Placeholder="orders/create" /></FlareCol>
                    <FlareCol Span="1"><FlareSelect TValue="string" Label="Connection" Size="FieldSize.Sm" @bind-Value="_editing.ConnectionName" Items="@ConnectionNames" /></FlareCol>
                    <FlareCol Span="1"><FlareSelect TValue="DbObjectType" Label="Object type" Size="FieldSize.Sm" @bind-Value="_editing.ObjectType" Items="Enum.GetValues<DbObjectType>()" ItemLabel="@(v => ObjectTypeLabel(v))" /></FlareCol>
                    <FlareCol Span="1"><FlareField Label="Schema" Size="FieldSize.Sm" @bind-Value="_editing.Schema" /></FlareCol>
                    <FlareCol Span="1"><FlareField Label="Object" Size="FieldSize.Sm" @bind-Value="_editing.ObjectName" Placeholder="usp_CreateOrder" /></FlareCol>
                    <FlareCol Span="1"><FlareSelect TValue="ResultMode" Label="Result mode" Size="FieldSize.Sm" @bind-Value="_editing.ResultMode" Items="Enum.GetValues<ResultMode>()" ItemLabel="@(v => v.ToString())" /></FlareCol>
                    <FlareCol Span="1"><FlareNumericField TValue="int?" Label="Timeout (s)" Size="FieldSize.Sm" @bind-Value="_editing.CommandTimeoutSeconds" /></FlareCol>
                </FlareGrid>

                <FlareStack Row Gap="FlareSpacing.Large" Wrap="true">
                    <FlareSwitch Value="_editing.Enabled" ValueChanged="@(v => _editing.Enabled = v)" Label="Enabled" />
                    <FlareSwitch Value="_editing.SuppressMessages" ValueChanged="@(v => _editing.SuppressMessages = v)" Label="Suppress SQL messages" />
                </FlareStack>

                <FlareDivider Text="Caching" TextAlign="DividerTextAlign.Left" />
                <FlareStack Row Gap="FlareSpacing.Large" Wrap="true" Align="FlareAlignItems.Center">
                    <FlareSwitch Value="_editing.CacheEnabled" ValueChanged="@(v => _editing.CacheEnabled = v)" Label="Enable cache" />
                    <FlareNumericField TValue="int" Label="TTL (s)" Size="FieldSize.Sm" @bind-Value="_editing.CacheTtlSeconds" Style="max-width:9rem;" />
                    <FlareSwitch Value="_editing.CacheVaryByApiKey" ValueChanged="@(v => _editing.CacheVaryByApiKey = v)" Label="Vary by API key" />
                </FlareStack>
                @if (_editing.CacheEnabled)
                {
                    <div>
                        <FlareText Typo="TypographyScale.LabelMedium" Color="FlareColor.OnSurfaceVariant">Vary cache by parameters</FlareText>
                        @if (_editing.Parameters.Count == 0)
                        {
                            <FlareText Typo="TypographyScale.BodySmall" Color="FlareColor.OnSurfaceVariant">No parameters defined; one response is cached for the whole endpoint.</FlareText>
                        }
                        else
                        {
                            <FlareStack Row Wrap="true" Gap="FlareSpacing.XSmall">
                                @foreach (var parameter in _editing.Parameters)
                                {
                                    var on = _editing.CacheVaryBy.Contains(parameter.Name);
                                    <FlareChip Size="ChipSize.Sm" Label="@parameter.Name"
                                               Variant="@(on ? ChipVariant.Filled : ChipVariant.Outlined)"
                                               Color="@(on ? FlareColor.Primary : FlareColor.Default)"
                                               OnClick="@(() => ToggleCacheVary(parameter.Name, !on))" />
                                }
                            </FlareStack>
                        }
                        <FlareText Typo="TypographyScale.LabelSmall" Color="FlareColor.OnSurfaceVariant">Selected parameters (and, if set, the API key) become part of the cache key, so callers with different values get separate cached responses. Leave empty to cache one shared response per endpoint. The row cap and TTL bound each entry.</FlareText>
                    </div>
                }

                <FlareDivider Text="Logging" TextAlign="DividerTextAlign.Left" />
                <FlareStack Row Gap="FlareSpacing.Large" Wrap="true" Align="FlareAlignItems.Center">
                    <FlareSwitch Value="_editing.LogEnabled" ValueChanged="@(v => _editing.LogEnabled = v)" Label="Log requests" />
                    <FlareSwitch Value="_editing.LogParameters" ValueChanged="@(v => _editing.LogParameters = v)" Label="Capture parameters" />
                    <FlareSwitch Value="_editing.LogResult" ValueChanged="@(v => _editing.LogResult = v)" Label="Capture result" />
                    <FlareNumericField TValue="int?" Label="Slow threshold %" Size="FieldSize.Sm" @bind-Value="_editing.SlowThresholdPercent" Placeholder="from settings" Style="max-width:12rem;" />
                </FlareStack>
                <FlareText Typo="TypographyScale.LabelSmall" Color="FlareColor.OnSurfaceVariant">Parameter and result capture can hold PII; enable only where needed. A call is flagged slow when it exceeds this endpoint's rolling average by the threshold (blank uses the global setting).</FlareText>

                <div>
                    <FlareText Typo="TypographyScale.LabelMedium" Color="FlareColor.OnSurfaceVariant">Required scopes</FlareText>
                    @if (_scopes is null || _scopes.Count == 0)
                    {
                        <FlareText Typo="TypographyScale.BodySmall" Color="FlareColor.OnSurfaceVariant">No scopes defined.</FlareText>
                    }
                    else
                    {
                        <FlareStack Row Wrap="true" Gap="FlareSpacing.XSmall">
                            @foreach (var scope in _scopes)
                            {
                                var selected = _editing.Scopes.Contains(scope.Name);
                                <FlareChip Size="ChipSize.Sm" Label="@scope.Name" Variant="@(selected ? ChipVariant.Filled : ChipVariant.Outlined)" Color="@(selected ? FlareColor.Primary : FlareColor.Default)" OnClick="@(() => ToggleScope(scope.Name, !selected))" />
                            }
                        </FlareStack>
                    }
                </div>

                <FlareDivider Text="Parameters" TextAlign="DividerTextAlign.Left" />
                <FlareStack Row Align="FlareAlignItems.Center" Gap="FlareSpacing.Small">
                    <FlareButton Variant="ButtonVariant.Outlined" Size="ButtonSize.Sm" OnClick="DiscoverParametersAsync" Loading="_discovering">Discover from database</FlareButton>
                    @if (_discoverError is not null)
                    {
                        <FlareText Typo="TypographyScale.BodySmall" Color="FlareColor.Error">@_discoverError</FlareText>
                    }
                </FlareStack>
                @foreach (var parameter in _editing.Parameters)
                {
                    <FlareCard Variant="CardVariant.Outlined" Compact="true">
                        <FlareStack Gap="FlareSpacing.XSmall">
                            <FlareStack Row Gap="FlareSpacing.XSmall" Align="FlareAlignItems.Center" Wrap="true">
                                <FlareField TValue="string" Placeholder="name" Size="FieldSize.Sm" @bind-Value="parameter.Name" />
                                <FlareSelect TValue="ParameterSource" Size="FieldSize.Sm" @bind-Value="parameter.Source" Items="Enum.GetValues<ParameterSource>()" ItemLabel="@(v => v.ToString())" />
                                <FlareSelect TValue="Weir.Contracts.ParameterDirection" Size="FieldSize.Sm" @bind-Value="parameter.Direction" Items="Enum.GetValues<Weir.Contracts.ParameterDirection>()" ItemLabel="@(v => v.ToString())" />
                                <FlareSelect TValue="WeirDbType" Size="FieldSize.Sm" @bind-Value="parameter.DbType" Items="Enum.GetValues<WeirDbType>()" ItemLabel="@(v => v.ToString())" />
                                <FlareNumericField TValue="int?" Placeholder="size" Size="FieldSize.Sm" @bind-Value="parameter.Size" Style="max-width:6rem;" />
                                <FlareButton Variant="ButtonVariant.Text" Color="FlareColor.Error" Size="ButtonSize.Sm" OnClick="@(() => RemoveParameter(parameter))">Remove</FlareButton>
                            </FlareStack>
                            @if (parameter.DbType == WeirDbType.Structured)
                            {
                                <FlareField TValue="string" Placeholder="TVP type e.g. dbo.OrderLineType" Size="FieldSize.Sm" @bind-Value="parameter.TypeName" />
                                @foreach (var column in parameter.Columns)
                                {
                                    <FlareStack Row Gap="FlareSpacing.XSmall" Align="FlareAlignItems.Center">
                                        <FlareField TValue="string" Placeholder="column" Size="FieldSize.Sm" @bind-Value="column.Name" />
                                        <FlareSelect TValue="WeirDbType" Size="FieldSize.Sm" @bind-Value="column.DbType" Items="Enum.GetValues<WeirDbType>()" ItemLabel="@(v => v.ToString())" />
                                        <FlareTooltip Content="Remove column" Arrow="true">
                                            <FlareButton Variant="ButtonVariant.Text" Color="FlareColor.Error" Size="ButtonSize.Sm" OnClick="@(() => RemoveColumn(parameter, column))">x</FlareButton>
                                        </FlareTooltip>
                                    </FlareStack>
                                }
                                <FlareButton Variant="ButtonVariant.Text" Size="ButtonSize.Sm" OnClick="@(() => AddColumn(parameter))">Add column</FlareButton>
                            }
                        </FlareStack>
                    </FlareCard>
                }
                <FlareStack Row><FlareButton Variant="ButtonVariant.Outlined" Size="ButtonSize.Sm" OnClick="AddParameter">Add parameter</FlareButton></FlareStack>

                <FlareDivider />
                <FlareStack Row Gap="FlareSpacing.Small" Justify="FlareJustifyContent.End">
                    <FlareButton Variant="ButtonVariant.Text" OnClick="CancelEdit">Cancel</FlareButton>
                    <FlareButton Variant="ButtonVariant.Filled" Color="FlareColor.Primary" OnClick="SaveAsync" Loading="_busy">Save endpoint</FlareButton>
                </FlareStack>
            </FlareStack>
        }
    </ChildContent>
</FlareDrawer>

@* ===== Test drawer ===== *@
<FlareDrawer Open="@(_testing is not null)" OpenChanged="@(open => { if (!open) CloseTest(); })" Anchor="DrawerAnchor.Right" Width="44rem" Variant="DrawerVariant.Temporary">
    <Header>
        <FlareStack Row Align="FlareAlignItems.Center" Gap="FlareSpacing.Small">
            <FlareText Typo="TypographyScale.TitleMedium">Test</FlareText>
            @if (_testing is not null)
            {
                <FlareText Element="span" Mono="true" Weight="FontWeight.Bold" Color="@MethodColor(_testing.HttpMethod)">@_testing.HttpMethod</FlareText>
                <FlareText Element="span" Mono="true" Color="FlareColor.OnSurfaceVariant">/api/@_testing.Route</FlareText>
            }
        </FlareStack>
    </Header>
    <ChildContent>
        @if (_testing is not null)
        {
            <FlareStack Gap="FlareSpacing.Medium">
                <FlareStack Row Align="FlareAlignItems.Center" Justify="FlareJustifyContent.SpaceBetween">
                    <FlareText Typo="TypographyScale.TitleSmall">Parameters</FlareText>
                    <FlareSwitch Value="_testRaw" ValueChanged="ToggleRaw" Label="Raw JSON" />
                </FlareStack>

                @if (_testRaw)
                {
                    <FlareTextArea @bind-Value="_testRawBody" Rows="10" />
                }
                else if (_testInputParameters.Count == 0)
                {
                    <FlareText Color="FlareColor.OnSurfaceVariant">This endpoint takes no input parameters.</FlareText>
                }
                else
                {
                    @foreach (var parameter in _testInputParameters)
                    {
                        <FlareStack Gap="FlareSpacing.None">
                            @if (parameter.DbType == WeirDbType.Boolean)
                            {
                                <FlareCheckbox Label="@parameter.Name" Value="GetTestBool(parameter.Name)" ValueChanged="@(v => SetTestBool(parameter.Name, v == true))" />
                            }
                            else if (parameter.DbType == WeirDbType.Structured)
                            {
                                <FlareText Typo="TypographyScale.LabelMedium" Mono="true">@parameter.Name</FlareText>
                                @if (parameter.TableColumns is { Count: > 0 })
                                {
                                    @foreach (var row in TestRows(parameter))
                                    {
                                        <FlareStack Row Gap="FlareSpacing.XSmall" Align="FlareAlignItems.Center">
                                            @foreach (var column in parameter.TableColumns)
                                            {
                                                <FlareField TValue="string" Placeholder="@column.Name" Size="FieldSize.Sm" Value="@GetCell(row, column.Name)" ValueChanged="@(v => SetCell(row, column.Name, v))" />
                                            }
                                        </FlareStack>
                                    }
                                    <FlareButton Variant="ButtonVariant.Text" Size="ButtonSize.Sm" OnClick="@(() => AddTestRow(parameter))">Add row</FlareButton>
                                }
                                else
                                {
                                    <FlareText Typo="TypographyScale.BodySmall" Color="FlareColor.OnSurfaceVariant">No column metadata; use Raw JSON.</FlareText>
                                }
                            }
                            else
                            {
                                <FlareField TValue="string" Label="@parameter.Name" HelperText="@TestParamHint(parameter)" Size="FieldSize.Sm" Type="@InputType(parameter.DbType)" Value="@GetTestValue(parameter.Name)" ValueChanged="@(v => SetTestValue(parameter.Name, v))" />
                            }
                        </FlareStack>
                    }
                }

                @if (_testResponse is not null)
                {
                    <FlareDivider Text="Response" TextAlign="DividerTextAlign.Left" />
                    <FlareCodeBlock Value="@_testResponse" Language="json" ReadOnly="true" />
                }

                <FlareDivider />
                <FlareStack Row Gap="FlareSpacing.Small" Justify="FlareJustifyContent.End">
                    <FlareButton Variant="ButtonVariant.Text" OnClick="CloseTest">Close</FlareButton>
                    <FlareButton Variant="ButtonVariant.Filled" Color="FlareColor.Primary" OnClick="SendTestAsync" Loading="_testBusy">Send request</FlareButton>
                </FlareStack>
            </FlareStack>
        }
    </ChildContent>
</FlareDrawer>

@code {
    private static readonly string[] _methods = ["GET", "POST", "PUT", "PATCH", "DELETE"];

    private List<EndpointDefinition>? _endpoints;
    private List<Scope>? _scopes;
    private List<ConnectionInfo>? _connections;
    private List<ApiKeyInfo>? _keys;
    private HashSet<string> _linked = new(StringComparer.OrdinalIgnoreCase);

    // Endpoint list filter: narrow to endpoints that require a scope, and/or that a key could reach.
    // Export and the OpenAPI document both honour the active filter, so an integrator can be handed
    // exactly the surface a given key sees.
    private string _filterScope = string.Empty;
    private string _filterKeyId = string.Empty;
    private EndpointEditModel? _editing;
    private bool _busy;
    private bool _discovering;
    private string? _discoverError;
    private string? _exportUrl;
    private string? _openApiUrl;
    private string? _notice;
    private bool _openApiBusy;
    private bool _syncBusy;

    // Database tab
    private int _epTabIndex;
    private string _dbConnection = string.Empty;
    private List<DbObjectDescriptor>? _objects;
    private string? _objectsError;
    private DbObjectDescriptor? _selectedObject;
    private List<DbParameterDescriptor>? _selectedParameters;

    // Test console
    private EndpointDefinition? _testing;
    private readonly Dictionary<string, string?> _testValues = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, List<Dictionary<string, string?>>> _testRows = new(StringComparer.OrdinalIgnoreCase);
    private List<EndpointParameter> _testInputParameters = [];
    private bool _testRaw;
    private string _testRawBody = "{}";
    private string? _testResponse;
    private bool _testBusy;

    /// <summary>Connection names for the toolbar and editor selectors.</summary>
    private IEnumerable<string> ConnectionNames => _connections?.Select(c => c.Name) ?? [];

    /// <summary>Loads endpoints, scopes, connections and keys (keys drive the "reachable by key" filter).</summary>
    protected override async Task OnInitializedAsync()
    {
        _endpoints = await Api.GetEndpointsAsync();
        _scopes = await Api.GetScopesAsync();
        _connections = await Api.GetConnectionsAsync();
        _keys = await Api.GetKeysAsync();
        _dbConnection = _endpoints?.FirstOrDefault()?.ConnectionName
            ?? _connections?.FirstOrDefault()?.Name
            ?? string.Empty;
        RebuildLinked();
    }

    // ----- Endpoint filter (by required scope / reachable by key) ---------------------------------

    /// <summary>Whether a scope or key filter is currently applied.</summary>
    private bool IsFiltered => !string.IsNullOrEmpty(_filterScope) || !string.IsNullOrEmpty(_filterKeyId);

    /// <summary>The selected key's id, or null when no key filter is active.</summary>
    private Guid? FilterKeyId => Guid.TryParse(_filterKeyId, out var id) ? id : null;

    /// <summary>The endpoints after applying the active scope and/or key filter.</summary>
    private List<EndpointDefinition> FilteredEndpoints
    {
        get
        {
            IEnumerable<EndpointDefinition> query = _endpoints ?? [];
            if (!string.IsNullOrEmpty(_filterScope))
            {
                query = query.Where(e => e.RequiredScopes.Contains(_filterScope, StringComparer.Ordinal));
            }

            if (FilterKeyId is { } keyId && _keys?.FirstOrDefault(k => k.Id == keyId) is { } key)
            {
                query = query.Where(e => KeyCanReach(key, e));
            }

            return query.ToList();
        }
    }

    /// <summary>
    /// Whether the key could call the endpoint: it must hold every required scope and (unless it has
    /// no grants, meaning unrestricted) at least one grant must match the endpoint's procedure. Mirrors
    /// the server-side <c>EndpointAccess</c> so the grid preview matches the generated OpenAPI document.
    /// </summary>
    /// <param name="key">The API key to test.</param>
    /// <param name="endpoint">The endpoint to test.</param>
    /// <returns>True if the key would be authorized to call the endpoint.</returns>
    private static bool KeyCanReach(ApiKeyInfo key, EndpointDefinition endpoint)
    {
        if (endpoint.RequiredScopes.Count > 0)
        {
            var granted = new HashSet<string>(key.Scopes, StringComparer.Ordinal);
            if (endpoint.RequiredScopes.Any(scope => !granted.Contains(scope)))
            {
                return false;
            }
        }

        return key.Grants.Count == 0
            || key.Grants.Any(grant => grant.Allows(endpoint.ConnectionName, endpoint.Schema, endpoint.ObjectName));
    }

    /// <summary>Options for the scope filter: an "all" sentinel plus each defined scope name.</summary>
    private IEnumerable<string> ScopeFilterOptions => new[] { string.Empty }.Concat(_scopes?.Select(s => s.Name) ?? []);

    /// <summary>Label for a scope filter option ("All scopes" for the empty sentinel).</summary>
    /// <param name="value">The scope name, or empty for the sentinel.</param>
    /// <returns>The display label.</returns>
    private static string ScopeFilterLabel(string value) => string.IsNullOrEmpty(value) ? "All scopes" : value;

    /// <summary>Options for the key filter: an "all" sentinel plus each key id (as a string).</summary>
    private IEnumerable<string> KeyFilterOptions => new[] { string.Empty }.Concat(_keys?.Select(k => k.Id.ToString()) ?? []);

    /// <summary>Label for a key filter option ("All keys" for the empty sentinel, otherwise the key name).</summary>
    /// <param name="value">The key id string, or empty for the sentinel.</param>
    /// <returns>The display label.</returns>
    private string KeyFilterLabel(string value)
    {
        if (string.IsNullOrEmpty(value))
        {
            return "All keys";
        }

        var key = _keys?.FirstOrDefault(k => k.Id.ToString() == value);
        return key is null ? value : key.Name;
    }

    /// <summary>Applies the chosen scope filter.</summary>
    /// <param name="value">The selected scope, or empty for all.</param>
    private void OnFilterScopeChanged(string? value) => _filterScope = value ?? string.Empty;

    /// <summary>Applies the chosen key filter.</summary>
    /// <param name="value">The selected key id, or empty for all.</param>
    private void OnFilterKeyChanged(string? value) => _filterKeyId = value ?? string.Empty;

    /// <summary>Clears both filters.</summary>
    private void ClearFilters()
    {
        _filterScope = string.Empty;
        _filterKeyId = string.Empty;
    }

    /// <summary>Reloads the endpoint list and the linked-object set.</summary>
    private async Task LoadAsync()
    {
        _endpoints = await Api.GetEndpointsAsync();
        RebuildLinked();
    }

    /// <summary>Recomputes which database objects already have an endpoint mapped to them.</summary>
    private void RebuildLinked() =>
        _linked = (_endpoints ?? []).Select(e => e.Schema + "." + e.ObjectName).ToHashSet(StringComparer.OrdinalIgnoreCase);

    /// <summary>Endpoints mapped to a given database object (there can be several, e.g. a GET and a POST).</summary>
    /// <param name="schema">The object's schema.</param>
    /// <param name="name">The object's name.</param>
    /// <returns>The matching endpoint definitions, newest binding order.</returns>
    private IReadOnlyList<EndpointDefinition> EndpointsForObject(string schema, string name) =>
        (_endpoints ?? [])
            .Where(e => string.Equals(e.Schema, schema, StringComparison.OrdinalIgnoreCase)
                     && string.Equals(e.ObjectName, name, StringComparison.OrdinalIgnoreCase))
            .ToList();

