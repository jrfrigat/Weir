@page "/scopes"
@attribute [Authorize]
@inherits LocalizedPage
@inject WeirApiClient Api
@inject IDialogService Dialog

<FlareStack Gap="FlareSpacing.Medium">
    <PageHeader Title="@AdminStrings.Scopes_Title" Description="@AdminStrings.Scopes_Description">
        <Actions>
            <FlareButton Variant="ButtonVariant.Filled" Color="FlareColor.Primary" Size="ButtonSize.Sm" OnClick="() => _showAdd = !_showAdd">@AdminStrings.Scopes_NewScope</FlareButton>
        </Actions>
    </PageHeader>

    @if (_showAdd)
    {
        <FlareCard Variant="CardVariant.Outlined">
            <FlareStack Row Align="FlareAlignItems.End" Gap="FlareSpacing.Small" Wrap="true">
                <FlareField Label="@AdminStrings.Common_Name" @bind-Value="_name" Placeholder="orders:read" />
                <FlareField Label="@AdminStrings.Common_Description" @bind-Value="_description" />
                <FlareButton Variant="ButtonVariant.Filled" Color="FlareColor.Primary" OnClick="AddAsync">@AdminStrings.Scopes_AddScope</FlareButton>
            </FlareStack>
        </FlareCard>
    }

    @if (_scopes is null)
    {
        <FlareText Color="FlareColor.OnSurfaceVariant">@AdminStrings.Common_Loading</FlareText>
    }
    else if (_scopes.Count == 0)
    {
        <FlareEmptyState Title="@AdminStrings.Scopes_EmptyTitle" Description="@AdminStrings.Scopes_EmptyDescription">
            <Icon><FlareIcon Name="lock" /></Icon>
        </FlareEmptyState>
    }
    else
    {
        <FlareDataGrid Items="@_scopes" Dense="true" Striped="true" Hoverable="true">
            <Columns>
                <FlareColumn TItem="Scope" Id="scope" Title="@AdminStrings.Scopes_ColumnScope" Field="@(s => (object?)s.Name)" Sortable="true" Filterable="true">
                    <Template><FlareCode>@context.Name</FlareCode></Template>
                </FlareColumn>
                <FlareColumn TItem="Scope" Id="description" Title="@AdminStrings.Common_Description" Field="@(s => (object?)s.Description)" Sortable="true" Filterable="true" />
                <FlareColumn TItem="Scope" Id="keys" Title="@AdminStrings.Scopes_ColumnKeys" Align="ColumnAlign.End">
                    <Template><FlareText Element="span" Mono="true" Color="FlareColor.OnSurfaceVariant">@KeyCount(context.Name)</FlareText></Template>
                </FlareColumn>
                <FlareColumn TItem="Scope" Id="endpoints" Title="@AdminStrings.Scopes_ColumnEndpoints" Align="ColumnAlign.End">
                    <Template><FlareText Element="span" Mono="true" Color="FlareColor.OnSurfaceVariant">@EndpointCount(context.Name)</FlareText></Template>
                </FlareColumn>
                <FlareColumn TItem="Scope" Id="actions" Title="" Align="ColumnAlign.End">
                    <Template>
                        <FlareButton Variant="ButtonVariant.Text" Color="FlareColor.Error" Size="ButtonSize.Sm" OnClick="@(() => DeleteAsync(context.Name))">@AdminStrings.Common_Delete</FlareButton>
                    </Template>
                </FlareColumn>
            </Columns>
        </FlareDataGrid>
    }
</FlareStack>

@code {
    private List<Scope>? _scopes;
    private IReadOnlyList<ApiKeyInfo> _keys = [];
    private IReadOnlyList<EndpointDefinition> _endpoints = [];
    private string _name = string.Empty;
    private string? _description;
    private bool _showAdd;

    /// <summary>Loads the scope list plus keys and endpoints (for the usage counts).</summary>
    protected override async Task OnInitializedAsync() => await LoadAsync();

    /// <summary>Reloads the scope list and the keys / endpoints that reference scopes.</summary>
    private async Task LoadAsync()
    {
        _keys = await Api.GetKeysAsync() ?? [];
        _endpoints = await Api.GetEndpointsAsync() ?? [];
        _scopes = await Api.GetScopesAsync();
    }

    /// <summary>Number of API keys that carry the given scope.</summary>
    /// <param name="scope">The scope name.</param>
    /// <returns>The count of keys granting this scope.</returns>
    private int KeyCount(string scope) =>
        _keys.Count(k => k.Scopes.Contains(scope, StringComparer.OrdinalIgnoreCase));

    /// <summary>Number of endpoints that require the given scope.</summary>
    /// <param name="scope">The scope name.</param>
    /// <returns>The count of endpoints requiring this scope.</returns>
    private int EndpointCount(string scope) =>
        _endpoints.Count(e => e.RequiredScopes.Contains(scope, StringComparer.OrdinalIgnoreCase));

    /// <summary>Adds or updates a scope.</summary>
    private async Task AddAsync()
    {
        if (string.IsNullOrWhiteSpace(_name))
        {
            return;
        }

        await Api.SaveScopeAsync(new Scope { Name = _name, Description = _description });
        _name = string.Empty;
        _description = null;
        _showAdd = false;
        await LoadAsync();
    }

    /// <summary>Confirms, then deletes a scope and reloads.</summary>
    /// <param name="name">The scope name.</param>
    private async Task DeleteAsync(string name)
    {
        var inUse = KeyCount(name) + EndpointCount(name);
        var suffix = inUse > 0
            ? string.Format(AdminStrings.Scopes_DeleteInUseSuffix, KeyCount(name), EndpointCount(name))
            : string.Empty;
        var confirmed = await Dialog.ConfirmAsync(
            AdminStrings.Scopes_DeleteConfirmTitle,
            string.Format(AdminStrings.Scopes_DeleteConfirmBody, name, suffix),
            AdminStrings.Common_Delete,
            AdminStrings.Common_Cancel);
        if (confirmed != true)
        {
            return;
        }

        await Api.DeleteScopeAsync(name);
        await LoadAsync();
    }
}
