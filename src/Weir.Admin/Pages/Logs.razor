@page "/logs"
@attribute [Authorize]
@using System.Globalization
@using System.Text.Json
@inject WeirApiClient Api
@inject NavigationManager Nav

<FlareStack Gap="FlareSpacing.Medium">
    <PageHeader Title="logs" Description="Data-plane request history - timing, results and slow calls">
        <Actions>
            @if (_endpointLabel is not null)
            {
                <FlareChip Size="ChipSize.Sm" Variant="ChipVariant.Outlined" Color="FlareColor.Primary" Label="@($"endpoint: {_endpointLabel}")" />
                <FlareButton Variant="ButtonVariant.Text" Size="ButtonSize.Sm" OnClick="ClearEndpoint">Clear</FlareButton>
            }
            <FlareButton Variant="ButtonVariant.Outlined" Size="ButtonSize.Sm" OnClick="RefreshAsync" Loading="_loading">Refresh</FlareButton>
        </Actions>
    </PageHeader>

    <FlareStack Row Align="FlareAlignItems.Center" Gap="FlareSpacing.Medium" Wrap="true">
        <FlareText Typo="TypographyScale.LabelMedium" Mono="true" Color="FlareColor.OnSurfaceVariant" Style="letter-spacing:.1em;">// FILTER</FlareText>
        <FlareSwitch Value="_slowOnly" ValueChanged="OnSlowOnlyChanged" Label="Slow only" />
        <FlareSwitch Value="_errorsOnly" ValueChanged="OnErrorsOnlyChanged" Label="Errors only" />
        @if (_entries is { Count: > 0 })
        {
            <FlareText Typo="TypographyScale.LabelSmall" Color="FlareColor.OnSurfaceVariant">@_entries.Count loaded</FlareText>
        }
    </FlareStack>

    @if (_entries is null)
    {
        <FlareText Color="FlareColor.OnSurfaceVariant">Loading...</FlareText>
    }
    else if (_entries.Count == 0)
    {
        <FlareEmptyState Title="No requests logged yet" Description="Calls appear here once the data plane serves them (request logging is enabled in Settings).">
            <Icon><FlareIcon Name="receipt_long" /></Icon>
        </FlareEmptyState>
    }
    else
    {
        <FlareDataGrid TItem="RequestLogEntry" Items="@_entries" Dense="true" Striped="true" Hoverable="true" FilterMode="DataGridFilterMode.Simple" RowClick="@(e => OpenDetail(e))">
            <Columns>
                <FlareColumn TItem="RequestLogEntry" Title="Time" Field="@(e => (object?)e.Timestamp.ToLocalTime().ToString("MM-dd HH:mm:ss"))" Filterable="true" FilterType="ColumnFilterType.Date" FilterFunc="@FilterTime" />
                <FlareColumn TItem="RequestLogEntry" Title="Method" Filterable="true" FilterType="ColumnFilterType.Select" FilterOptions="@_methodOptions" FilterFunc="@FilterMethod">
                    <Template><FlareText Element="span" Mono="true" Weight="FontWeight.Bold" Color="@MethodColor(context.HttpMethod)">@context.HttpMethod</FlareText></Template>
                </FlareColumn>
                <FlareColumn TItem="RequestLogEntry" Title="Route" Field="@(e => (object?)e.Route)" Filterable="true" FilterFunc="@FilterLike">
                    <Template><FlareText Element="span" Mono="true">/@context.Route</FlareText></Template>
                </FlareColumn>
                <FlareColumn TItem="RequestLogEntry" Title="Object" Field="@(e => (object?)e.ObjectName)" Filterable="true" FilterFunc="@FilterLike" />
                <FlareColumn TItem="RequestLogEntry" Title="Status" Align="ColumnAlign.End" Filterable="true" FilterFunc="@FilterBetweenInt">
                    <Template><FlareText Element="span" Mono="true" Color="@StatusColor(context.StatusCode)">@(context.StatusCode?.ToString() ?? "-")</FlareText></Template>
                </FlareColumn>
                <FlareColumn TItem="RequestLogEntry" Title="Duration" Align="ColumnAlign.End" Filterable="true" FilterFunc="@FilterBetweenDouble">
                    <Template>
                        <FlareStack Row Gap="FlareSpacing.XSmall" Align="FlareAlignItems.Center" Justify="FlareJustifyContent.End">
                            @if (context.Slow)
                            {
                                <FlareTooltip Content="@SlowHint(context)" Arrow="true"><FlareIcon Name="warning" Size="0.85rem" Color="FlareColor.Warning" /></FlareTooltip>
                            }
                            <FlareText Element="span" Mono="true" Color="@(context.Slow ? FlareColor.Warning : FlareColor.OnSurface)">@Ms(context.DurationMs)</FlareText>
                        </FlareStack>
                    </Template>
                </FlareColumn>
                <FlareColumn TItem="RequestLogEntry" Title="DB" Align="ColumnAlign.End" Field="@(e => (object?)(e.DbDurationMs.HasValue ? Ms(e.DbDurationMs.Value) : "-"))" Filterable="true" FilterFunc="@FilterBetweenDoubleNullable" />
                <FlareColumn TItem="RequestLogEntry" Title="Rows" Align="ColumnAlign.End" Field="@(e => (object?)(e.CacheHit ? "cache" : e.RowsReturned?.ToString() ?? "-"))" Filterable="true" FilterFunc="@FilterLikeRows" />
                <FlareColumn TItem="RequestLogEntry" Title="Caller" Field="@(e => (object?)e.ApiKeyPrefix)" Filterable="true" FilterFunc="@FilterLike">
                    <Template><FlareText Element="span" Mono="true" Color="FlareColor.OnSurfaceVariant">@context.ApiKeyPrefix</FlareText></Template>
                </FlareColumn>
            </Columns>
        </FlareDataGrid>

        <FlareStack Row Align="FlareAlignItems.Center" Gap="FlareSpacing.Small">
            @if (_hasMore)
            {
                <FlareButton Variant="ButtonVariant.Tonal" Size="ButtonSize.Sm" OnClick="LoadOlderAsync" Disabled="_loadingMore">Load older</FlareButton>
            }
            @if (_loadingMore)
            {
                <FlareText Typo="TypographyScale.LabelSmall" Color="FlareColor.OnSurfaceVariant">Loading...</FlareText>
            }
        </FlareStack>
    }
</FlareStack>

@* ===== Detail drawer ===== *@
<FlareDrawer Open="@(_selected is not null)" OpenChanged="@(open => { if (!open) _selected = null; })" Anchor="DrawerAnchor.Right" Width="42rem" Variant="DrawerVariant.Temporary">
    <Header>
        @if (_selected is not null)
        {
            <FlareStack Row Align="FlareAlignItems.Center" Gap="FlareSpacing.Small">
                <FlareText Element="span" Mono="true" Weight="FontWeight.Bold" Color="@MethodColor(_selected.HttpMethod)">@_selected.HttpMethod</FlareText>
                <FlareText Typo="TypographyScale.TitleMedium" Mono="true">/@_selected.Route</FlareText>
            </FlareStack>
        }
    </Header>
    <ChildContent>
        @if (_selected is not null)
        {
            <FlareStack Gap="FlareSpacing.Medium">
                @* Timing breakdown *@
                @{
                    var total = _selected.DurationMs;
                    var db = _selected.DbDurationMs ?? 0;
                    var overhead = Math.Max(0, total - db);
                    var maxBar = Math.Max(total, 1);
                }
                <FlareCard Variant="CardVariant.Outlined">
                    <FlareText Typo="TypographyScale.LabelMedium" Mono="true" Color="FlareColor.OnSurfaceVariant" Style="letter-spacing:.1em;">// TIMING BREAKDOWN</FlareText>
                    <div style="display:flex;gap:2px;height:24px;border-radius:4px;overflow:hidden;margin:0.5rem 0;">
                        @if (db > 0)
                        {
                            <div style="width:@(db / maxBar * 100)%;background:var(--flare-color-error);min-width:2px;" title="DB: @Ms(db)"></div>
                        }
                        @if (overhead > 0)
                        {
                            <div style="width:@(overhead / maxBar * 100)%;background:var(--flare-color-on-surface-variant);min-width:2px;" title="Other: @Ms(overhead)"></div>
                        }
                    </div>
                    <FlareStack Row Gap="FlareSpacing.Medium" Wrap="true">
                        @if (db > 0)
                        {
                            <FlareStack Row Align="FlareAlignItems.Center" Gap="FlareSpacing.XSmall">
                                <div style="width:10px;height:10px;border-radius:2px;background:var(--flare-color-error);"></div>
                                <FlareText Typo="TypographyScale.LabelSmall" Mono="true">DB @Ms(db)</FlareText>
                            </FlareStack>
                        }
                        <FlareStack Row Align="FlareAlignItems.Center" Gap="FlareSpacing.XSmall">
                            <div style="width:10px;height:10px;border-radius:2px;background:var(--flare-color-on-surface-variant);"></div>
                            <FlareText Typo="TypographyScale.LabelSmall" Mono="true">Other @Ms(overhead)</FlareText>
                        </FlareStack>
                        <FlareDivider Vertical="true" Style="height:14px;" />
                        <FlareText Typo="TypographyScale.LabelSmall" Mono="true" Color="FlareColor.OnSurfaceVariant">Total @Ms(total)</FlareText>
                        @if (_selected.AverageMs is { } avg)
                        {
                            <FlareText Typo="TypographyScale.LabelSmall" Mono="true" Color="FlareColor.OnSurfaceVariant">avg @Ms(avg)</FlareText>
                        }
                    </FlareStack>
                </FlareCard>

                <FlareDescriptionList>
                    <FlareDescriptionItem Label="Time"><FlareText Mono="true">@_selected.Timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</FlareText></FlareDescriptionItem>
                    <FlareDescriptionItem Label="Object"><FlareText Mono="true">@_selected.ObjectName</FlareText></FlareDescriptionItem>
                    <FlareDescriptionItem Label="Connection"><FlareText Mono="true">@_selected.ConnectionName</FlareText></FlareDescriptionItem>
                    <FlareDescriptionItem Label="Status"><FlareText Mono="true" Color="@StatusColor(_selected.StatusCode)">@(_selected.StatusCode?.ToString() ?? "-") (@_selected.Outcome)</FlareText></FlareDescriptionItem>
                    <FlareDescriptionItem Label="Duration"><FlareText Mono="true" Color="@(_selected.Slow ? FlareColor.Warning : FlareColor.OnSurface)">@Ms(_selected.DurationMs)@(_selected.Slow ? " (slow)" : "")</FlareText></FlareDescriptionItem>
                    @if (_selected.DbDurationMs is { } db)
                    {
                        <FlareDescriptionItem Label="Database time"><FlareText Mono="true">@Ms(db)</FlareText></FlareDescriptionItem>
                    }
                    @if (_selected.AverageMs is { } avg)
                    {
                        <FlareDescriptionItem Label="Endpoint average"><FlareText Mono="true">@Ms(avg)</FlareText></FlareDescriptionItem>
                    }
                    <FlareDescriptionItem Label="Rows"><FlareText Mono="true">@(_selected.CacheHit ? "served from cache" : _selected.RowsReturned?.ToString() ?? "-")</FlareText></FlareDescriptionItem>
                    <FlareDescriptionItem Label="Caller"><FlareText Mono="true">@_selected.ApiKeyPrefix</FlareText></FlareDescriptionItem>
                </FlareDescriptionList>

                @if (!string.IsNullOrEmpty(_selected.Error))
                {
                    <FlareAlert Severity="AlertSeverity.Error" Title="Error">@_selected.Error</FlareAlert>
                }

                @if (!string.IsNullOrEmpty(_selected.Parameters))
                {
                    <FlareDivider Text="Parameters" TextAlign="DividerTextAlign.Left" />
                    <FlareCodeBlock Value="@Pretty(_selected.Parameters)" Language="json" ReadOnly="true" />
                }

                @if (!string.IsNullOrEmpty(_selected.Result))
                {
                    <FlareDivider Text="Result" TextAlign="DividerTextAlign.Left" />
                    <FlareCodeBlock Value="@Pretty(_selected.Result)" Language="json" ReadOnly="true" />
                }

                @if (string.IsNullOrEmpty(_selected.Parameters) && string.IsNullOrEmpty(_selected.Result))
                {
                    <FlareText Typo="TypographyScale.BodySmall" Color="FlareColor.OnSurfaceVariant">
                        Parameter and result capture is off for this endpoint. Enable it per endpoint in the endpoint editor's Logging section.
                    </FlareText>
                }
            </FlareStack>
        }
    </ChildContent>
</FlareDrawer>

@code {
    private static readonly CultureInfo Invariant = CultureInfo.InvariantCulture;
    private const int PageSize = 100;

    private List<RequestLogEntry>? _entries;
    private RequestLogEntry? _selected;
    private Guid? _endpointId;
    private string? _endpointLabel;
    private bool _slowOnly;
    private bool _errorsOnly;
    private bool _loading;
    private bool _loadingMore;
    private bool _hasMore;

    private string? _route;

    /// <summary>Optional endpoint id from the query string, to pre-filter the log to one endpoint.</summary>
    [Parameter, SupplyParameterFromQuery(Name = "endpoint")]
    public Guid? EndpointParam { get; set; }

    /// <summary>Optional route from the query string, to pre-filter the log (used by the dashboard drill-in).</summary>
    [Parameter, SupplyParameterFromQuery(Name = "route")]
    public string? RouteParam { get; set; }

    /// <summary>Optional human-readable endpoint label from the query string (for the filter chip).</summary>
    [Parameter, SupplyParameterFromQuery(Name = "label")]
    public string? LabelParam { get; set; }

    /// <summary>Reads the optional endpoint / route filter from the query string and loads the first page.</summary>
    protected override async Task OnInitializedAsync()
    {
        if (EndpointParam is { } id)
        {
            _endpointId = id;
            _endpointLabel = string.IsNullOrEmpty(LabelParam) ? id.ToString()[..8] : LabelParam;
        }
        else if (!string.IsNullOrEmpty(RouteParam))
        {
            _route = RouteParam;
            _endpointLabel = string.IsNullOrEmpty(LabelParam) ? RouteParam : LabelParam;
        }

        await RefreshAsync();
    }

    /// <summary>Loads the newest page for the current filter.</summary>
    private async Task RefreshAsync()
    {
        _loading = true;
        _selected = null;
        try
        {
            _entries = await Api.GetRequestLogAsync(_endpointId, _route, _slowOnly, _errorsOnly, PageSize) ?? [];
            _hasMore = _entries.Count == PageSize;
        }
        finally
        {
            _loading = false;
        }
    }

    /// <summary>Fetches the next older page using the last entry's id as the keyset cursor.</summary>
    private async Task LoadOlderAsync()
    {
        if (_entries is null || _entries.Count == 0)
        {
            return;
        }

        _loadingMore = true;
        try
        {
            var older = await Api.GetRequestLogAsync(_endpointId, _route, _slowOnly, _errorsOnly, PageSize, _entries[^1].Id);
            if (older is { Count: > 0 })
            {
                _entries.AddRange(older);
            }

            _hasMore = older is { Count: PageSize };
        }
        finally
        {
            _loadingMore = false;
        }
    }

    private async Task OnSlowOnlyChanged(bool value)
    {
        _slowOnly = value;
        await RefreshAsync();
    }

    private async Task OnErrorsOnlyChanged(bool value)
    {
        _errorsOnly = value;
        await RefreshAsync();
    }

    /// <summary>Removes the per-endpoint filter and reloads the full log.</summary>
    private async Task ClearEndpoint()
    {
        _endpointId = null;
        _route = null;
        _endpointLabel = null;
        Nav.NavigateTo("logs");
        await RefreshAsync();
    }

    private void OpenDetail(RequestLogEntry entry) => _selected = entry;

    /// <summary>Formats a millisecond duration with up to one decimal.</summary>
    private static string Ms(double ms) => ms.ToString("0.#", Invariant) + "ms";

    /// <summary>Tooltip explaining why a call was flagged slow.</summary>
    private static string SlowHint(RequestLogEntry entry) =>
        entry.AverageMs is { } avg
            ? $"Slower than usual: {Ms(entry.DurationMs)} vs {Ms(avg)} average"
            : "Slower than usual for this endpoint";

    /// <summary>Pretty-prints a captured JSON string, falling back to the raw text.</summary>
    private static string Pretty(string raw)
    {
        try
        {
            using var document = JsonDocument.Parse(raw);
            return JsonSerializer.Serialize(document, new JsonSerializerOptions { WriteIndented = true });
        }
        catch (JsonException)
        {
            return raw;
        }
    }

    /// <summary>Colours an HTTP method label like the endpoint list does.</summary>
    private static FlareColor MethodColor(string method) => (method ?? string.Empty).ToUpperInvariant() switch
    {
        "GET" => FlareColor.Info,
        "POST" => FlareColor.Success,
        "PUT" or "PATCH" => FlareColor.Warning,
        "DELETE" => FlareColor.Error,
        _ => FlareColor.OnSurfaceVariant,
    };

    /// <summary>Colours a status code: red for failures, muted otherwise.</summary>
    private static FlareColor StatusColor(int? status) =>
        status >= 500 ? FlareColor.Error
        : status >= 400 ? FlareColor.Warning
        : FlareColor.OnSurfaceVariant;

    // ===== Column filters =====

    private static readonly string[] _methodOptions = ["GET", "POST", "PUT", "PATCH", "DELETE"];

    private static bool FilterTime(RequestLogEntry entry, string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return true;
        }

        if (DateTime.TryParse(value, CultureInfo.InvariantCulture, DateTimeStyles.None, out var date))
        {
            var entryDate = entry.Timestamp.Date;
            return entryDate == date;
        }

        return true;
    }

    private static bool FilterMethod(RequestLogEntry entry, string? value)
    {
        return string.IsNullOrWhiteSpace(value) || string.Equals(entry.HttpMethod, value, StringComparison.OrdinalIgnoreCase);
    }

    private static bool FilterLike(RequestLogEntry entry, string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return true;
        }

        var field = entry.Route ?? string.Empty;
        return field.Contains(value, StringComparison.OrdinalIgnoreCase);
    }

    private static bool FilterLikeRows(RequestLogEntry entry, string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return true;
        }

        var text = entry.CacheHit ? "cache" : entry.RowsReturned?.ToString() ?? "-";
        return text.Contains(value, StringComparison.OrdinalIgnoreCase);
    }

    private static bool FilterBetweenInt(RequestLogEntry entry, string? value)
    {
        if (string.IsNullOrWhiteSpace(value) || entry.StatusCode is null)
        {
            return true;
        }

        return TryParseBetween(value, out var min, out var max) && entry.StatusCode.Value >= min && entry.StatusCode.Value <= max;
    }

    private static bool FilterBetweenDouble(RequestLogEntry entry, string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return true;
        }

        return TryParseBetweenDouble(value, out var min, out var max) && entry.DurationMs >= min && entry.DurationMs <= max;
    }

    private static bool FilterBetweenDoubleNullable(RequestLogEntry entry, string? value)
    {
        if (string.IsNullOrWhiteSpace(value) || entry.DbDurationMs is null)
        {
            return true;
        }

        return TryParseBetweenDouble(value, out var min, out var max) && entry.DbDurationMs.Value >= min && entry.DbDurationMs.Value <= max;
    }

    private static bool TryParseBetween(string value, out int min, out int max)
    {
        min = 0;
        max = int.MaxValue;
        var parts = value.Split('-', 2, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 2 && int.TryParse(parts[0], out min) && int.TryParse(parts[1], out max))
        {
            return true;
        }

        if (int.TryParse(value, out var single))
        {
            min = single;
            max = single;
            return true;
        }

        return false;
    }

    private static bool TryParseBetweenDouble(string value, out double min, out double max)
    {
        min = 0;
        max = double.MaxValue;
        var parts = value.Split('-', 2, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 2 && double.TryParse(parts[0], NumberStyles.Float, Invariant, out min) && double.TryParse(parts[1], NumberStyles.Float, Invariant, out max))
        {
            return true;
        }

        if (double.TryParse(value, NumberStyles.Float, Invariant, out var single))
        {
            min = single;
            max = single;
            return true;
        }

        return false;
    }
}
