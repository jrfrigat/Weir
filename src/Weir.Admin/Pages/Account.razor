@page "/account"
@attribute [Authorize]
@inherits LocalizedPage
@inject WeirApiClient Api
@inject IFlareClipboard Clipboard

<FlareStack Gap="FlareSpacing.Medium" Style="max-width:34rem;">
    <PageHeader Title="@AdminStrings.Account_Title" Description="@AdminStrings.Account_Description" />

    <FlareCard Variant="CardVariant.Outlined">
        <FlareStack Gap="FlareSpacing.Small">
            <FlareText Typo="TypographyScale.TitleMedium">@AdminStrings.Account_Profile</FlareText>
            <FlareDescriptionList>
                <FlareDescriptionItem Label="@AdminStrings.Account_Username"><FlareText Mono="true">@(_me?.Username ?? "...")</FlareText></FlareDescriptionItem>
                <FlareDescriptionItem Label="@AdminStrings.Account_Role">
                    @if (_me is not null)
                    {
                        <FlareStack Row Align="FlareAlignItems.Center" Gap="FlareSpacing.Small">
                            <FlareChip Size="ChipSize.Sm" Variant="ChipVariant.Filled" Color="@(_me.Role == AdminRoles.Admin ? FlareColor.Primary : FlareColor.Default)" Label="@_me.Role" />
                            <FlareText Typo="TypographyScale.BodySmall" Color="FlareColor.OnSurfaceVariant">@(_me.Role == AdminRoles.Admin ? AdminStrings.Account_RoleFullAccess : AdminStrings.Account_RoleReadOnly)</FlareText>
                        </FlareStack>
                    }
                </FlareDescriptionItem>
            </FlareDescriptionList>
        </FlareStack>
    </FlareCard>

    <FlareCard Variant="CardVariant.Outlined">
        <FlareStack Gap="FlareSpacing.Small">
            <FlareText Typo="TypographyScale.TitleMedium">@AdminStrings.Account_ChangePasswordHeading</FlareText>
            <FlarePasswordField Label="@AdminStrings.Account_CurrentPassword" @bind-Value="_current" autocomplete="current-password" />
            <FlarePasswordField Label="@AdminStrings.Account_NewPassword" @bind-Value="_new" autocomplete="new-password" />
            <FlarePasswordField Label="@AdminStrings.Account_ConfirmNewPassword" @bind-Value="_confirm" autocomplete="new-password" />
            <FlareStack Row>
                <FlareButton Variant="ButtonVariant.Filled" Color="FlareColor.Primary" OnClick="ChangeAsync" Loading="_busy">@AdminStrings.Account_ChangePasswordButton</FlareButton>
            </FlareStack>
            @if (_message is not null)
            {
                <FlareAlert Severity="@(_ok ? AlertSeverity.Success : AlertSeverity.Error)">@_message</FlareAlert>
            }
        </FlareStack>
    </FlareCard>

    <FlareCard Variant="CardVariant.Outlined">
        <FlareStack Gap="FlareSpacing.Small">
            <FlareText Typo="TypographyScale.TitleMedium">@AdminStrings.Account_AccessTokens</FlareText>
            <FlareText Typo="TypographyScale.BodySmall" Color="FlareColor.OnSurfaceVariant">
                @AdminStrings.Account_TokensIntro
                <FlareCode>Authorization: Bearer &lt;token&gt;</FlareCode>.
            </FlareText>

            @if (_createdToken is not null)
            {
                <FlareAlert Severity="AlertSeverity.Success" Title="@AdminStrings.Account_TokenCreatedTitle">
                    <FlareStack Gap="FlareSpacing.Small">
                        <FlareText Typo="TypographyScale.BodySmall" Color="FlareColor.OnSurfaceVariant">@AdminStrings.Account_TokenCreatedBody</FlareText>
                        <FlareStack Row Align="FlareAlignItems.Center" Gap="FlareSpacing.Small" Wrap="true">
                            <FlareCode>@_createdToken.PlainTextToken</FlareCode>
                            <FlareButton Variant="ButtonVariant.Filled" Color="FlareColor.Primary" Size="ButtonSize.Sm" OnClick="() => CopyAsync(_createdToken.PlainTextToken)">@(_copied ? AdminStrings.Account_Copied : AdminStrings.Common_Copy)</FlareButton>
                            <FlareButton Variant="ButtonVariant.Text" Size="ButtonSize.Sm" OnClick="() => { _createdToken = null; _copied = false; }">@AdminStrings.Account_Done</FlareButton>
                        </FlareStack>
                    </FlareStack>
                </FlareAlert>
            }

            <FlareStack Row Align="FlareAlignItems.End" Gap="FlareSpacing.Small" Wrap="true">
                <FlareField Label="@AdminStrings.Common_Name" @bind-Value="_tokenName" Placeholder="@AdminStrings.Account_TokenNamePlaceholder" />
                <FlareField Label="@AdminStrings.Account_TokenExpiryLabel" @bind-Value="_tokenExpiryDays" Placeholder="@AdminStrings.Account_TokenExpiryPlaceholder" />
                <FlareButton Variant="ButtonVariant.Filled" Color="FlareColor.Primary" OnClick="CreateTokenAsync" Loading="_tokenBusy">@AdminStrings.Account_CreateToken</FlareButton>
            </FlareStack>
            @if (_tokenError is not null)
            {
                <FlareAlert Severity="AlertSeverity.Error">@_tokenError</FlareAlert>
            }

            @if (_tokens is null)
            {
                <FlareText Color="FlareColor.OnSurfaceVariant">@AdminStrings.Common_Loading</FlareText>
            }
            else if (_tokens.Count == 0)
            {
                <FlareText Typo="TypographyScale.BodySmall" Color="FlareColor.OnSurfaceVariant">@AdminStrings.Account_NoTokens</FlareText>
            }
            else
            {
                <FlareDataGrid Items="@_tokens" Dense="true" Striped="true">
                    <Columns>
                        <FlareColumn TItem="AdminTokenInfo" Title="@AdminStrings.Common_Name" Field="@(t => (object?)t.Name)" />
                        <FlareColumn TItem="AdminTokenInfo" Title="@AdminStrings.Account_ColumnToken">
                            <Template><FlareText Element="span" Mono="true" Color="FlareColor.OnSurfaceVariant">@context.Prefix</FlareText></Template>
                        </FlareColumn>
                        <FlareColumn TItem="AdminTokenInfo" Title="@AdminStrings.Account_ColumnCreated" Field="@(t => (object?)t.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd"))" />
                        <FlareColumn TItem="AdminTokenInfo" Title="@AdminStrings.Account_ColumnExpires" Field="@(t => (object?)(t.ExpiresAt.HasValue ? t.ExpiresAt.Value.ToLocalTime().ToString("yyyy-MM-dd") : AdminStrings.Account_Never))" />
                        <FlareColumn TItem="AdminTokenInfo" Title="@AdminStrings.Account_ColumnLastUsed" Field="@(t => (object?)(t.LastUsedAt.HasValue ? t.LastUsedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "-"))" />
                        <FlareColumn TItem="AdminTokenInfo" Title="" Align="ColumnAlign.End">
                            <Template>
                                <FlareButton Variant="ButtonVariant.Text" Color="FlareColor.Error" Size="ButtonSize.Sm" OnClick="@(() => RevokeTokenAsync(context.Id))">@AdminStrings.Account_Revoke</FlareButton>
                            </Template>
                        </FlareColumn>
                    </Columns>
                </FlareDataGrid>
            }
        </FlareStack>
    </FlareCard>
</FlareStack>

@code {
    private CurrentAdmin? _me;
    private string _current = string.Empty;
    private string _new = string.Empty;
    private string _confirm = string.Empty;
    private bool _busy;
    private bool _ok;
    private string? _message;

    private List<AdminTokenInfo>? _tokens;
    private string _tokenName = string.Empty;
    private string _tokenExpiryDays = string.Empty;
    private bool _tokenBusy;
    private bool _copied;
    private string? _tokenError;
    private AdminTokenCreated? _createdToken;

    /// <summary>Loads the current admin's identity and access tokens.</summary>
    protected override async Task OnInitializedAsync()
    {
        _me = await Api.GetCurrentAdminAsync();
        await LoadTokensAsync();
    }

    /// <summary>Reloads the access-token list.</summary>
    private async Task LoadTokensAsync() => _tokens = await Api.GetAccountTokensAsync();

    /// <summary>Creates a personal access token and captures its plaintext for one-time display.</summary>
    private async Task CreateTokenAsync()
    {
        _tokenError = null;
        if (string.IsNullOrWhiteSpace(_tokenName))
        {
            _tokenError = AdminStrings.Account_ErrorTokenNameRequired;
            return;
        }

        DateTimeOffset? expiresAt = null;
        if (!string.IsNullOrWhiteSpace(_tokenExpiryDays))
        {
            if (!int.TryParse(_tokenExpiryDays, out var days) || days <= 0)
            {
                _tokenError = AdminStrings.Account_ErrorTokenExpiryInvalid;
                return;
            }

            expiresAt = DateTimeOffset.UtcNow.AddDays(days);
        }

        _tokenBusy = true;
        _createdToken = await Api.CreateAccountTokenAsync(new AdminTokenCreate { Name = _tokenName.Trim(), ExpiresAt = expiresAt });
        _tokenBusy = false;

        if (_createdToken is null)
        {
            _tokenError = AdminStrings.Account_ErrorTokenCreateFailed;
            return;
        }

        _copied = false;
        _tokenName = string.Empty;
        _tokenExpiryDays = string.Empty;
        await LoadTokensAsync();
    }

    /// <summary>Revokes an access token and reloads the list.</summary>
    /// <param name="id">The token id.</param>
    private async Task RevokeTokenAsync(Guid id)
    {
        await Api.RevokeAccountTokenAsync(id);
        await LoadTokensAsync();
    }

    /// <summary>Copies the plaintext token to the clipboard via Flare's clipboard service.</summary>
    /// <param name="token">The plaintext token.</param>
    private async Task CopyAsync(string token)
    {
        await Clipboard.CopyAsync(token);
        _copied = true;
    }

    /// <summary>Validates and submits the self password change.</summary>
    private async Task ChangeAsync()
    {
        _message = null;
        if (string.IsNullOrEmpty(_current) || string.IsNullOrEmpty(_new))
        {
            (_ok, _message) = (false, AdminStrings.Account_ErrorPasswordFieldsRequired);
            return;
        }

        if (_new != _confirm)
        {
            (_ok, _message) = (false, AdminStrings.Account_ErrorPasswordMismatch);
            return;
        }

        _busy = true;
        var ok = await Api.ChangeOwnPasswordAsync(new ChangeOwnPasswordRequest { CurrentPassword = _current, NewPassword = _new });
        _busy = false;

        if (ok)
        {
            (_ok, _message) = (true, AdminStrings.Account_PasswordChanged);
            _current = _new = _confirm = string.Empty;
        }
        else
        {
            (_ok, _message) = (false, AdminStrings.Account_ErrorCurrentPasswordIncorrect);
        }
    }
}
