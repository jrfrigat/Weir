@page "/account"
@attribute [Authorize]
@inject WeirApiClient Api
@inject IJSRuntime JS

<FlareStack Gap="FlareSpacing.Medium" Style="max-width:34rem;">
    <PageHeader Title="account" Description="Your profile, password and personal access tokens" />

    <FlareCard Variant="CardVariant.Outlined">
        <FlareStack Gap="FlareSpacing.Small">
            <FlareText Typo="TypographyScale.TitleMedium">Profile</FlareText>
            <FlareDescriptionList>
                <FlareDescriptionItem Label="Username"><FlareText Mono="true">@(_me?.Username ?? "...")</FlareText></FlareDescriptionItem>
                <FlareDescriptionItem Label="Role">
                    @if (_me is not null)
                    {
                        <FlareStack Row Align="FlareAlignItems.Center" Gap="FlareSpacing.Small">
                            <FlareChip Size="ChipSize.Sm" Variant="ChipVariant.Filled" Color="@(_me.Role == AdminRoles.Admin ? FlareColor.Primary : FlareColor.Default)" Label="@_me.Role" />
                            <FlareText Typo="TypographyScale.BodySmall" Color="FlareColor.OnSurfaceVariant">@(_me.Role == AdminRoles.Admin ? "full access" : "read-only")</FlareText>
                        </FlareStack>
                    }
                </FlareDescriptionItem>
            </FlareDescriptionList>
        </FlareStack>
    </FlareCard>

    <FlareCard Variant="CardVariant.Outlined">
        <FlareStack Gap="FlareSpacing.Small">
            <FlareText Typo="TypographyScale.TitleMedium">Change password</FlareText>
            <FlarePasswordField Label="Current password" @bind-Value="_current" autocomplete="current-password" />
            <FlarePasswordField Label="New password" @bind-Value="_new" autocomplete="new-password" />
            <FlarePasswordField Label="Confirm new password" @bind-Value="_confirm" autocomplete="new-password" />
            <FlareStack Row>
                <FlareButton Variant="ButtonVariant.Filled" Color="FlareColor.Primary" OnClick="ChangeAsync" Loading="_busy">Change password</FlareButton>
            </FlareStack>
            @if (_message is not null)
            {
                <FlareAlert Severity="@(_ok ? AlertSeverity.Success : AlertSeverity.Error)">@_message</FlareAlert>
            }
        </FlareStack>
    </FlareCard>

    <FlareCard Variant="CardVariant.Outlined">
        <FlareStack Gap="FlareSpacing.Small">
            <FlareText Typo="TypographyScale.TitleMedium">Access tokens</FlareText>
            <FlareText Typo="TypographyScale.BodySmall" Color="FlareColor.OnSurfaceVariant">
                Personal access tokens call the admin API as you (with your role), for scripts and CI/CD -
                for example to sync an endpoint's parameters on deploy. Send it as
                <FlareCode>Authorization: Bearer &lt;token&gt;</FlareCode>.
            </FlareText>

            @if (_createdToken is not null)
            {
                <FlareAlert Severity="AlertSeverity.Success" Title="Token created - copy it now">
                    <FlareStack Gap="FlareSpacing.Small">
                        <FlareText Typo="TypographyScale.BodySmall" Color="FlareColor.OnSurfaceVariant">This token is shown once and cannot be retrieved later.</FlareText>
                        <FlareStack Row Align="FlareAlignItems.Center" Gap="FlareSpacing.Small" Wrap="true">
                            <FlareCode>@_createdToken.PlainTextToken</FlareCode>
                            <FlareButton Variant="ButtonVariant.Filled" Color="FlareColor.Primary" Size="ButtonSize.Sm" OnClick="() => CopyAsync(_createdToken.PlainTextToken)">@(_copied ? "Copied" : "Copy")</FlareButton>
                            <FlareButton Variant="ButtonVariant.Text" Size="ButtonSize.Sm" OnClick="() => { _createdToken = null; _copied = false; }">Done</FlareButton>
                        </FlareStack>
                    </FlareStack>
                </FlareAlert>
            }

            <FlareStack Row Align="FlareAlignItems.End" Gap="FlareSpacing.Small" Wrap="true">
                <FlareField Label="Name" @bind-Value="_tokenName" Placeholder="e.g. ci-deploy" />
                <FlareField Label="Expires in days (blank = never)" @bind-Value="_tokenExpiryDays" Placeholder="e.g. 90" />
                <FlareButton Variant="ButtonVariant.Filled" Color="FlareColor.Primary" OnClick="CreateTokenAsync" Loading="_tokenBusy">Create token</FlareButton>
            </FlareStack>
            @if (_tokenError is not null)
            {
                <FlareAlert Severity="AlertSeverity.Error">@_tokenError</FlareAlert>
            }

            @if (_tokens is null)
            {
                <FlareText Color="FlareColor.OnSurfaceVariant">Loading...</FlareText>
            }
            else if (_tokens.Count == 0)
            {
                <FlareText Typo="TypographyScale.BodySmall" Color="FlareColor.OnSurfaceVariant">No tokens yet.</FlareText>
            }
            else
            {
                <FlareDataGrid Items="@_tokens" Dense="true" Striped="true">
                    <Columns>
                        <FlareColumn TItem="AdminTokenInfo" Title="Name" Field="@(t => (object?)t.Name)" />
                        <FlareColumn TItem="AdminTokenInfo" Title="Token">
                            <Template><FlareText Element="span" Mono="true" Color="FlareColor.OnSurfaceVariant">@context.Prefix</FlareText></Template>
                        </FlareColumn>
                        <FlareColumn TItem="AdminTokenInfo" Title="Created" Field="@(t => (object?)t.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd"))" />
                        <FlareColumn TItem="AdminTokenInfo" Title="Expires" Field="@(t => (object?)(t.ExpiresAt.HasValue ? t.ExpiresAt.Value.ToLocalTime().ToString("yyyy-MM-dd") : "never"))" />
                        <FlareColumn TItem="AdminTokenInfo" Title="Last used" Field="@(t => (object?)(t.LastUsedAt.HasValue ? t.LastUsedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "-"))" />
                        <FlareColumn TItem="AdminTokenInfo" Title="" Align="ColumnAlign.End">
                            <Template>
                                <FlareButton Variant="ButtonVariant.Text" Color="FlareColor.Error" Size="ButtonSize.Sm" OnClick="@(() => RevokeTokenAsync(context.Id))">Revoke</FlareButton>
                            </Template>
                        </FlareColumn>
                    </Columns>
                </FlareDataGrid>
            }
        </FlareStack>
    </FlareCard>
</FlareStack>

@code {
    private CurrentAdmin? _me;
    private string _current = string.Empty;
    private string _new = string.Empty;
    private string _confirm = string.Empty;
    private bool _busy;
    private bool _ok;
    private string? _message;

    private List<AdminTokenInfo>? _tokens;
    private string _tokenName = string.Empty;
    private string _tokenExpiryDays = string.Empty;
    private bool _tokenBusy;
    private bool _copied;
    private string? _tokenError;
    private AdminTokenCreated? _createdToken;

    /// <summary>Loads the current admin's identity and access tokens.</summary>
    protected override async Task OnInitializedAsync()
    {
        _me = await Api.GetCurrentAdminAsync();
        await LoadTokensAsync();
    }

    /// <summary>Reloads the access-token list.</summary>
    private async Task LoadTokensAsync() => _tokens = await Api.GetAccountTokensAsync();

    /// <summary>Creates a personal access token and captures its plaintext for one-time display.</summary>
    private async Task CreateTokenAsync()
    {
        _tokenError = null;
        if (string.IsNullOrWhiteSpace(_tokenName))
        {
            _tokenError = "Enter a name for the token.";
            return;
        }

        DateTimeOffset? expiresAt = null;
        if (!string.IsNullOrWhiteSpace(_tokenExpiryDays))
        {
            if (!int.TryParse(_tokenExpiryDays, out var days) || days <= 0)
            {
                _tokenError = "Expiry must be a positive number of days, or blank.";
                return;
            }

            expiresAt = DateTimeOffset.UtcNow.AddDays(days);
        }

        _tokenBusy = true;
        _createdToken = await Api.CreateAccountTokenAsync(new AdminTokenCreate { Name = _tokenName.Trim(), ExpiresAt = expiresAt });
        _tokenBusy = false;

        if (_createdToken is null)
        {
            _tokenError = "Could not create the token.";
            return;
        }

        _copied = false;
        _tokenName = string.Empty;
        _tokenExpiryDays = string.Empty;
        await LoadTokensAsync();
    }

    /// <summary>Revokes an access token and reloads the list.</summary>
    /// <param name="id">The token id.</param>
    private async Task RevokeTokenAsync(Guid id)
    {
        await Api.RevokeAccountTokenAsync(id);
        await LoadTokensAsync();
    }

    /// <summary>Copies the plaintext token to the clipboard.</summary>
    /// <param name="token">The plaintext token.</param>
    private async Task CopyAsync(string token)
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", token);
            _copied = true;
        }
        catch (JSException)
        {
            // Clipboard unavailable; the token is still selectable on screen.
        }
    }

    /// <summary>Validates and submits the self password change.</summary>
    private async Task ChangeAsync()
    {
        _message = null;
        if (string.IsNullOrEmpty(_current) || string.IsNullOrEmpty(_new))
        {
            (_ok, _message) = (false, "Fill in the current and new password.");
            return;
        }

        if (_new != _confirm)
        {
            (_ok, _message) = (false, "The new passwords do not match.");
            return;
        }

        _busy = true;
        var ok = await Api.ChangeOwnPasswordAsync(new ChangeOwnPasswordRequest { CurrentPassword = _current, NewPassword = _new });
        _busy = false;

        if (ok)
        {
            (_ok, _message) = (true, "Password changed.");
            _current = _new = _confirm = string.Empty;
        }
        else
        {
            (_ok, _message) = (false, "The current password is incorrect.");
        }
    }
}
