@page "/admins"
@attribute [Authorize]
@inherits LocalizedPage
@inject WeirApiClient Api

<FlareStack Gap="FlareSpacing.Medium">
    <PageHeader Title="@AdminStrings.Admins_Title" Description="@AdminStrings.Admins_Description">
        <Actions>
            <FlareButton Variant="ButtonVariant.Filled" Color="FlareColor.Primary" Size="ButtonSize.Sm" OnClick="() => _showAdd = !_showAdd">@AdminStrings.Admins_NewAdmin</FlareButton>
        </Actions>
    </PageHeader>

    @if (_showAdd)
    {
        <FlareCard Variant="CardVariant.Outlined">
            <FlareStack Row Align="FlareAlignItems.End" Gap="FlareSpacing.Small" Wrap="true">
                <FlareField Label="@AdminStrings.Admins_Username" @bind-Value="_username" autocomplete="off" />
                <FlarePasswordField Label="@AdminStrings.Admins_Password" @bind-Value="_password" autocomplete="new-password" />
                <FlareSelect TValue="string" Label="@AdminStrings.Admins_Role" @bind-Value="_role" Items="_roles" ItemLabel="RoleLabel" />
                <FlareButton Variant="ButtonVariant.Filled" Color="FlareColor.Primary" OnClick="CreateAsync">@AdminStrings.Common_Create</FlareButton>
                @if (_createMessage is not null)
                {
                    <FlareText Typo="TypographyScale.BodySmall" Color="FlareColor.OnSurfaceVariant">@_createMessage</FlareText>
                }
            </FlareStack>
        </FlareCard>
    }

    @if (_admins is null)
    {
        <FlareText Color="FlareColor.OnSurfaceVariant">@AdminStrings.Common_Loading</FlareText>
    }
    else if (_admins.Count == 0)
    {
        <FlareEmptyState Title="@AdminStrings.Admins_EmptyTitle" Description="@AdminStrings.Admins_EmptyDescription">
            <Icon><FlareIcon Name="group" /></Icon>
        </FlareEmptyState>
    }
    else
    {
        <FlareDataGrid Items="@_admins" Dense="true" Striped="true" Hoverable="true">
            <Columns>
                <FlareColumn TItem="AdminUserInfo" Id="login" Title="@AdminStrings.Admins_Login" Field="@(a => (object?)a.Username)" Sortable="true" Filterable="true">
                    <Template>
                        <FlareStack Row Align="FlareAlignItems.Center" Gap="FlareSpacing.XSmall">
                            <FlareAvatar Size="AvatarSize.Sm">@Initials(context.Username)</FlareAvatar>
                            <FlareText Element="span" Mono="true">@context.Username</FlareText>
                        </FlareStack>
                    </Template>
                </FlareColumn>
                <FlareColumn TItem="AdminUserInfo" Id="role" Title="@AdminStrings.Admins_Role">
                    <Template>
                        <FlareChip Size="ChipSize.Sm" Variant="ChipVariant.Filled" Color="@(context.Role == AdminRoles.Admin ? FlareColor.Primary : FlareColor.Default)" Label="@context.Role" />
                    </Template>
                </FlareColumn>
                <FlareColumn TItem="AdminUserInfo" Id="status" Title="@AdminStrings.Admins_Status">
                    <Template>
                        <FlareChip Size="ChipSize.Sm" Variant="ChipVariant.Filled" Color="@(context.Enabled ? FlareColor.Success : FlareColor.Error)" Label="@(context.Enabled ? AdminStrings.Admins_StatusEnabled : AdminStrings.Admins_StatusDisabled)" />
                    </Template>
                </FlareColumn>
                <FlareColumn TItem="AdminUserInfo" Id="last-login" Title="@AdminStrings.Admins_LastLogin" Field="@(a => (object?)(a.LastLoginAt.HasValue ? a.LastLoginAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "-"))" Sortable="true" />
                <FlareColumn TItem="AdminUserInfo" Id="created" Title="@AdminStrings.Admins_Created" Field="@(a => (object?)a.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd"))" Sortable="true" />
                <FlareColumn TItem="AdminUserInfo" Id="actions" Title="" Align="ColumnAlign.End">
                    <Template>
                        <FlareButton Variant="ButtonVariant.Text" Size="ButtonSize.Sm" OnClick="@(() => StartReset(context.Id))">@AdminStrings.Admins_ResetPassword</FlareButton>
                    </Template>
                </FlareColumn>
            </Columns>
        </FlareDataGrid>

        @if (_resettingId is not null)
        {
            <FlareCard Variant="CardVariant.Outlined" Style="max-width:34rem;">
                <FlareStack Gap="FlareSpacing.Small">
                    <FlareText Typo="TypographyScale.TitleSmall">@AdminStrings.Admins_ResetPassword</FlareText>
                    <FlarePasswordField Label="@AdminStrings.Admins_NewPassword" @bind-Value="_resetPassword" autocomplete="new-password" />
                    <FlareStack Row Gap="FlareSpacing.Small">
                        <FlareButton Variant="ButtonVariant.Filled" Color="FlareColor.Primary" OnClick="@(() => ResetAsync(_resettingId!.Value))" Loading="_resetBusy">@AdminStrings.Common_Save</FlareButton>
                        <FlareButton Variant="ButtonVariant.Text" OnClick="@(() => { _resettingId = null; })">@AdminStrings.Common_Cancel</FlareButton>
                    </FlareStack>
                    @if (_resetMessage is not null)
                    {
                        <FlareAlert Severity="AlertSeverity.Error">@_resetMessage</FlareAlert>
                    }
                </FlareStack>
            </FlareCard>
        }

        <FlareText Typo="TypographyScale.BodySmall" Color="FlareColor.OnSurfaceVariant">
            @AdminStrings.Admins_RoleNotePrefix<FlareLink Href="/account">@AdminStrings.Admins_AccountLink</FlareLink>@AdminStrings.Admins_RoleNoteSuffix
        </FlareText>
    }
</FlareStack>

@code {
    private static readonly string[] _roles = [AdminRoles.Admin, AdminRoles.Viewer];

    private List<AdminUserInfo>? _admins;
    private bool _showAdd;
    private string _username = string.Empty;
    private string _password = string.Empty;
    private string _role = AdminRoles.Admin;
    private string? _createMessage;
    private Guid? _resettingId;
    private string _resetPassword = string.Empty;
    private bool _resetBusy;
    private string? _resetMessage;

    /// <summary>Loads the admin list.</summary>
    protected override async Task OnInitializedAsync() => await LoadAsync();

    /// <summary>Reloads the admin list.</summary>
    private async Task LoadAsync() => _admins = await Api.GetAdminsAsync();

    /// <summary>Human-readable label for a role value in the selector.</summary>
    private static string RoleLabel(string role) => role == AdminRoles.Admin ? AdminStrings.Admins_RoleAdminFullAccess : AdminStrings.Admins_RoleViewerReadOnly;

    /// <summary>Creates an admin account and reloads.</summary>
    private async Task CreateAsync()
    {
        _createMessage = null;
        if (string.IsNullOrWhiteSpace(_username) || string.IsNullOrWhiteSpace(_password))
        {
            _createMessage = AdminStrings.Admins_EnterUsernameAndPassword;
            return;
        }

        await Api.CreateAdminAsync(new CreateAdminRequest { Username = _username, Password = _password, Role = _role });
        _username = string.Empty;
        _password = string.Empty;
        _role = AdminRoles.Admin;
        _showAdd = false;
        await LoadAsync();
    }

    /// <summary>Opens the inline password-reset panel for an admin.</summary>
    private void StartReset(Guid id)
    {
        _resettingId = id;
        _resetPassword = string.Empty;
        _resetMessage = null;
    }

    /// <summary>Resets an admin's password.</summary>
    private async Task ResetAsync(Guid id)
    {
        _resetMessage = null;
        if (string.IsNullOrWhiteSpace(_resetPassword))
        {
            _resetMessage = AdminStrings.Admins_EnterNewPassword;
            return;
        }

        _resetBusy = true;
        var ok = await Api.ResetAdminPasswordAsync(id, _resetPassword);
        _resetBusy = false;

        if (ok)
        {
            _resettingId = null;
            _resetPassword = string.Empty;
        }
        else
        {
            _resetMessage = AdminStrings.Admins_ResetFailedAdminRoleRequired;
        }
    }

    /// <summary>Two-letter uppercase initials from a username, for the avatar.</summary>
    /// <param name="name">The username.</param>
    /// <returns>Up to two uppercase letters, or "?" when unavailable.</returns>
    private static string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
        {
            return "?";
        }

        var letters = new string(name.Where(char.IsLetter).ToArray());
        return letters.Length == 0 ? "?" : letters[..Math.Min(2, letters.Length)].ToUpperInvariant();
    }
}
