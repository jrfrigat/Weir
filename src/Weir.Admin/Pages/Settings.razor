@page "/settings"
@attribute [Authorize]
@inherits LocalizedPage
@inject WeirApiClient Api
@inject IFlareDownload Download

<FlareStack Gap="FlareSpacing.Medium">
    <PageHeader Title="@AdminStrings.Settings_Title" Description="@AdminStrings.Settings_PageDescription" />

    @if (_loadFailed)
    {
        <FlareAlert Severity="AlertSeverity.Error" Title="@AdminStrings.Settings_LoadFailedTitle">@AdminStrings.Settings_LoadFailedBody</FlareAlert>
    }
    else if (_loading)
    {
        <FlareText Color="FlareColor.OnSurfaceVariant">@AdminStrings.Common_Loading</FlareText>
    }
    else
    {
        @if (_status is not null)
        {
            <FlareAlert Severity="@(_statusError ? AlertSeverity.Error : AlertSeverity.Success)">@_status</FlareAlert>
        }

        <FlareCard Variant="CardVariant.Outlined">
            <FlareStack Gap="FlareSpacing.Small">
                <FlareText Typo="TypographyScale.LabelMedium" Color="FlareColor.OnSurfaceVariant" Mono="true" Style="letter-spacing:.1em;">@AdminStrings.Settings_SectionDataPlaneLimits</FlareText>
                <FlareStack Row Gap="FlareSpacing.Medium" Wrap="true">
                    <FlareNumericField TValue="int" Label="@AdminStrings.Settings_MaxRowsLabel" Size="FieldSize.Sm" @bind-Value="_maxRows" Style="max-width:12rem;" />
                    <FlareNumericField TValue="int" Label="@AdminStrings.Settings_RequestTimeoutLabel" Size="FieldSize.Sm" @bind-Value="_requestTimeoutSeconds" HelperText="@DurationHint.Humanize(_requestTimeoutSeconds)" Style="max-width:12rem;" />
                    <FlareNumericField TValue="int" Label="@AdminStrings.Settings_MaxTvpRowsLabel" Size="FieldSize.Sm" @bind-Value="_maxTvpRows" Style="max-width:12rem;" />
                </FlareStack>
                <FlareText Typo="TypographyScale.LabelSmall" Color="FlareColor.OnSurfaceVariant">@AdminStrings.Settings_DataPlaneLimitsHelp</FlareText>
            </FlareStack>
        </FlareCard>

        <FlareCard Variant="CardVariant.Outlined">
            <FlareStack Gap="FlareSpacing.Small">
                <FlareText Typo="TypographyScale.LabelMedium" Color="FlareColor.OnSurfaceVariant" Mono="true" Style="letter-spacing:.1em;">@AdminStrings.Settings_SectionDelivery</FlareText>
                <FlareStack Row Gap="FlareSpacing.Medium" Wrap="true">
                    <FlareSelect TValue="ResponseDeliveryMode" Label="@AdminStrings.Settings_DeliveryModeLabel" Size="FieldSize.Sm"
                                 @bind-Value="_responseDeliveryMode" Items="Enum.GetValues<ResponseDeliveryMode>()"
                                 ItemLabel="DeliveryModeLabel" Style="min-width:16rem;" />
                    <FlareNumericField TValue="int" Label="@AdminStrings.Settings_ResponseFlushBytesLabel" Size="FieldSize.Sm" @bind-Value="_responseFlushBytes" Style="max-width:12rem;" />
                    <FlareSelect TValue="ResponseCompressionMode" Label="@AdminStrings.Settings_CompressionModeLabel" Size="FieldSize.Sm"
                                 @bind-Value="_responseCompressionMode" Items="Enum.GetValues<ResponseCompressionMode>()"
                                 ItemLabel="CompressionModeLabel" Style="min-width:16rem;" />
                </FlareStack>
                <FlareText Typo="TypographyScale.LabelSmall" Color="FlareColor.OnSurfaceVariant">@AdminStrings.Settings_DeliveryHelp</FlareText>
                @if (_responseFlushBytes >= LargeObjectHeapThresholdBytes)
                {
                    <FlareText Typo="TypographyScale.LabelSmall" Color="FlareColor.Warning">@AdminStrings.Common_FlushBytesLohWarning</FlareText>
                }
                else if (_responseFlushBytes is > 0 and < MinSensibleFlushBytes)
                {
                    <FlareText Typo="TypographyScale.LabelSmall" Color="FlareColor.Warning">@AdminStrings.Common_FlushBytesTinyWarning</FlareText>
                }
            </FlareStack>
        </FlareCard>

        <FlareCard Variant="CardVariant.Outlined">
            <FlareStack Gap="FlareSpacing.Small">
                <FlareText Typo="TypographyScale.LabelMedium" Color="FlareColor.OnSurfaceVariant" Mono="true" Style="letter-spacing:.1em;">@AdminStrings.Settings_SectionResponseCache</FlareText>
                <FlareNumericField TValue="long" Label="@AdminStrings.Settings_ResponseCacheMaxBytesLabel" Size="FieldSize.Sm" @bind-Value="_responseCacheMaxBytes" Style="max-width:16rem;" />
                <FlareText Typo="TypographyScale.LabelSmall" Color="FlareColor.OnSurfaceVariant">@AdminStrings.Settings_ResponseCacheHelp</FlareText>
            </FlareStack>
        </FlareCard>

        <FlareCard Variant="CardVariant.Outlined">
            <FlareStack Gap="FlareSpacing.Small">
                <FlareText Typo="TypographyScale.LabelMedium" Color="FlareColor.OnSurfaceVariant" Mono="true" Style="letter-spacing:.1em;">@AdminStrings.Settings_SectionRateLimiting</FlareText>
                <FlareStack Row Gap="FlareSpacing.Medium" Wrap="true">
                    <FlareNumericField TValue="int" Label="@AdminStrings.Settings_DefaultRateLimitLabel" Size="FieldSize.Sm" @bind-Value="_defaultRateLimit" Style="max-width:16rem;" />
                    <FlareNumericField TValue="int" Label="@AdminStrings.Settings_ApiKeyFailureThresholdLabel" Size="FieldSize.Sm" @bind-Value="_apiKeyFailureThreshold" Style="max-width:16rem;" />
                </FlareStack>
                <FlareText Typo="TypographyScale.LabelSmall" Color="FlareColor.OnSurfaceVariant">@AdminStrings.Settings_RateLimitingHelp</FlareText>
            </FlareStack>
        </FlareCard>

        <FlareCard Variant="CardVariant.Outlined">
            <FlareStack Gap="FlareSpacing.Small">
                <FlareText Typo="TypographyScale.LabelMedium" Color="FlareColor.OnSurfaceVariant" Mono="true" Style="letter-spacing:.1em;">@AdminStrings.Settings_SectionConnectionResilience</FlareText>
                <FlareStack Row Gap="FlareSpacing.Medium" Wrap="true">
                    <FlareNumericField TValue="int" Label="@AdminStrings.Settings_MaxConcurrentPerConnectionLabel" Size="FieldSize.Sm" @bind-Value="_maxConcurrentPerConnection" Style="max-width:16rem;" />
                    <FlareNumericField TValue="int" Label="@AdminStrings.Settings_CircuitBreakerThresholdLabel" Size="FieldSize.Sm" @bind-Value="_circuitBreakerThreshold" Style="max-width:14rem;" />
                    <FlareNumericField TValue="int" Label="@AdminStrings.Settings_CircuitBreakerResetLabel" Size="FieldSize.Sm" @bind-Value="_circuitBreakerResetSeconds" HelperText="@DurationHint.Humanize(_circuitBreakerResetSeconds)" Style="max-width:14rem;" />
                </FlareStack>
                <FlareText Typo="TypographyScale.LabelSmall" Color="FlareColor.OnSurfaceVariant">@AdminStrings.Settings_ConnectionResilienceHelp</FlareText>
            </FlareStack>
        </FlareCard>

        <FlareCard Variant="CardVariant.Outlined">
            <FlareStack Gap="FlareSpacing.Small">
                <FlareText Typo="TypographyScale.LabelMedium" Color="FlareColor.OnSurfaceVariant" Mono="true" Style="letter-spacing:.1em;">@AdminStrings.Settings_SectionAudit</FlareText>
                <FlareNumericField TValue="int" Label="@AdminStrings.Settings_AuditRetentionLabel" Size="FieldSize.Sm" @bind-Value="_auditRetentionDays" Style="max-width:16rem;" />
                <FlareText Typo="TypographyScale.LabelSmall" Color="FlareColor.OnSurfaceVariant">@AdminStrings.Settings_AuditHelp</FlareText>
            </FlareStack>
        </FlareCard>

        <FlareCard Variant="CardVariant.Outlined">
            <FlareStack Gap="FlareSpacing.Small">
                <FlareText Typo="TypographyScale.LabelMedium" Color="FlareColor.OnSurfaceVariant" Mono="true" Style="letter-spacing:.1em;">@AdminStrings.Settings_SectionRequestLog</FlareText>
                <FlareStack Row Gap="FlareSpacing.Medium" Wrap="true" Align="FlareAlignItems.Center">
                    <FlareSwitch Value="_requestLogEnabled" ValueChanged="@(v => _requestLogEnabled = v)" Label="@AdminStrings.Settings_EnableRequestLogLabel" />
                    <FlareNumericField TValue="int" Label="@AdminStrings.Settings_SlowThresholdLabel" Size="FieldSize.Sm" @bind-Value="_slowThresholdPercent" Style="max-width:12rem;" />
                    <FlareNumericField TValue="int" Label="@AdminStrings.Settings_RequestLogRetentionLabel" Size="FieldSize.Sm" @bind-Value="_requestLogRetentionDays" Style="max-width:12rem;" />
                </FlareStack>
                <FlareText Typo="TypographyScale.LabelSmall" Color="FlareColor.OnSurfaceVariant">@AdminStrings.Settings_RequestLogHelp</FlareText>
            </FlareStack>
        </FlareCard>

        <FlareStack Row Gap="FlareSpacing.Small" Align="FlareAlignItems.Center">
            <FlareButton Variant="ButtonVariant.Filled" Color="FlareColor.Primary" OnClick="SaveAsync" Disabled="_saving">@AdminStrings.Settings_SaveButton</FlareButton>
            @if (_saving)
            {
                <FlareText Typo="TypographyScale.LabelSmall" Color="FlareColor.OnSurfaceVariant">@AdminStrings.Common_Saving</FlareText>
            }
        </FlareStack>

        <FlareCard Variant="CardVariant.Outlined">
            <FlareStack Gap="FlareSpacing.Small">
                <FlareText Typo="TypographyScale.LabelMedium" Color="FlareColor.OnSurfaceVariant" Mono="true" Style="letter-spacing:.1em;">@AdminStrings.Settings_SectionBackupExport</FlareText>
                <FlareStack Row Gap="FlareSpacing.Small" Align="FlareAlignItems.Center" Wrap="true">
                    <FlareButton Variant="ButtonVariant.Tonal" Size="ButtonSize.Sm" OnClick="ExportAsync" Disabled="_exporting">@AdminStrings.Settings_GenerateExportButton</FlareButton>
                    @if (_exporting)
                    {
                        <FlareText Typo="TypographyScale.LabelSmall" Color="FlareColor.OnSurfaceVariant">@AdminStrings.Settings_Preparing</FlareText>
                    }
                </FlareStack>
                <FlareText Typo="TypographyScale.LabelSmall" Color="FlareColor.OnSurfaceVariant">@AdminStrings.Settings_BackupExportHelp</FlareText>
            </FlareStack>
        </FlareCard>

        <FlareCard Variant="CardVariant.Filled">
            <FlareStack Gap="FlareSpacing.XSmall">
                <FlareText Typo="TypographyScale.LabelMedium" Color="FlareColor.OnSurfaceVariant" Mono="true" Style="letter-spacing:.1em;">@AdminStrings.Settings_SectionLogging</FlareText>
                <FlareDescriptionList>
                    <FlareDescriptionItem Label="@AdminStrings.Settings_MaxRequestBodyLabel"><FlareText Mono="true">@_maxRequestBodyBytes.ToString("#,##0")</FlareText></FlareDescriptionItem>
                    @if (_logging is not null)
                    {
                        <FlareDescriptionItem Label="@AdminStrings.Settings_FileLoggingLabel"><FlareText Mono="true">@(_logging.FileEnabled ? AdminStrings.Settings_On : AdminStrings.Settings_Off)</FlareText></FlareDescriptionItem>
                        <FlareDescriptionItem Label="@AdminStrings.Settings_DirectoryLabel"><FlareText Mono="true">@_logging.Directory</FlareText></FlareDescriptionItem>
                        <FlareDescriptionItem Label="@AdminStrings.Settings_RollingLabel"><FlareText Mono="true">@_logging.RollingInterval</FlareText></FlareDescriptionItem>
                        <FlareDescriptionItem Label="@AdminStrings.Settings_RetainedFilesLabel"><FlareText Mono="true">@(_logging.RetainedFileCountLimit?.ToString() ?? AdminStrings.Settings_RetainedFilesAll)</FlareText></FlareDescriptionItem>
                        <FlareDescriptionItem Label="@AdminStrings.Settings_FormatLabel"><FlareText Mono="true">@_logging.Format</FlareText></FlareDescriptionItem>
                        <FlareDescriptionItem Label="@AdminStrings.Settings_LevelLabel"><FlareText Mono="true">@_logging.MinimumLevel</FlareText></FlareDescriptionItem>
                    }
                </FlareDescriptionList>
                <FlareText Typo="TypographyScale.LabelSmall" Color="FlareColor.OnSurfaceVariant">@AdminStrings.Settings_LoggingHelp</FlareText>
            </FlareStack>
        </FlareCard>
    }
</FlareStack>

@code {
    private bool _loading = true;
    private bool _loadFailed;
    private bool _saving;
    private string? _status;
    private bool _statusError;

    private int _maxRows;
    private int _requestTimeoutSeconds;
    private int _maxTvpRows;
    private int _defaultRateLimit;
    private int _apiKeyFailureThreshold;
    private int _auditRetentionDays;
    private int _maxConcurrentPerConnection;
    private int _circuitBreakerThreshold;
    private int _circuitBreakerResetSeconds;
    private bool _requestLogEnabled;
    private int _slowThresholdPercent;
    private int _requestLogRetentionDays;
    private long _responseCacheMaxBytes;
    private ResponseDeliveryMode _responseDeliveryMode;
    private int _responseFlushBytes;
    private ResponseCompressionMode _responseCompressionMode;
    private long _maxRequestBodyBytes;
    private WeirLoggingInfo? _logging;
    private bool _exporting;
    /// <summary>Loads the current settings into the editable fields.</summary>
    protected override async Task OnInitializedAsync() => await LoadAsync();

    /// <summary>Fetches the settings view and populates the form, flagging a load failure.</summary>
    private async Task LoadAsync()
    {
        _loading = true;
        _loadFailed = false;
        try
        {
            var view = await Api.GetSettingsAsync();
            if (view is null)
            {
                _loadFailed = true;
                return;
            }

            _maxRows = view.Settings.MaxRows;
            _requestTimeoutSeconds = view.Settings.RequestTimeoutSeconds;
            _maxTvpRows = view.Settings.MaxTvpRows;
            _defaultRateLimit = view.Settings.DefaultApiKeyRateLimitPerMinute;
            _apiKeyFailureThreshold = view.Settings.ApiKeyFailureThreshold;
            _auditRetentionDays = view.Settings.AuditRetentionDays;
            _maxConcurrentPerConnection = view.Settings.MaxConcurrentRequestsPerConnection;
            _circuitBreakerThreshold = view.Settings.CircuitBreakerFailureThreshold;
            _circuitBreakerResetSeconds = view.Settings.CircuitBreakerResetSeconds;
            _requestLogEnabled = view.Settings.RequestLogEnabled;
            _slowThresholdPercent = view.Settings.SlowRequestThresholdPercent;
            _requestLogRetentionDays = view.Settings.RequestLogRetentionDays;
            _responseCacheMaxBytes = view.Settings.ResponseCacheMaxBytes;
            _responseDeliveryMode = view.Settings.ResponseDeliveryMode;
            _responseFlushBytes = view.Settings.ResponseFlushBytes;
            _responseCompressionMode = view.Settings.ResponseCompressionMode;
            _maxRequestBodyBytes = view.MaxRequestBodyBytes;
            _logging = view.Logging;
        }
        catch (HttpRequestException)
        {
            _loadFailed = true;
        }
        finally
        {
            _loading = false;
        }
    }

    /// <summary>Fetches the control-plane export and downloads it via Flare's download service.</summary>
    private async Task ExportAsync()
    {
        _exporting = true;
        _status = null;
        try
        {
            var json = await Api.GetControlPlaneExportAsync();
            if (json is null)
            {
                _status = AdminStrings.Settings_ExportRejected;
                _statusError = true;
                return;
            }

            await Download.DownloadAsync("weir-control-plane.json", json, "application/json");
            _status = AdminStrings.Settings_ExportDownloaded;
            _statusError = false;
        }
        catch (HttpRequestException)
        {
            _status = AdminStrings.Settings_ExportServiceUnavailable;
            _statusError = true;
        }
        finally
        {
            _exporting = false;
        }
    }

    /// <summary>Validates and persists the edited settings, surfacing success or the failure reason.</summary>
    private async Task SaveAsync()
    {
        if (_maxRows < 0 || _requestTimeoutSeconds < 0 || _maxTvpRows < 0 || _defaultRateLimit < 0 || _auditRetentionDays < 0 ||
            _maxConcurrentPerConnection < 0 || _circuitBreakerThreshold < 0 || _circuitBreakerResetSeconds < 0 ||
            _apiKeyFailureThreshold < 0 || _slowThresholdPercent < 0 || _requestLogRetentionDays < 0 || _responseCacheMaxBytes < 0)
        {
            _status = AdminStrings.Settings_ValuesMustNotBeNegative;
            _statusError = true;
            return;
        }

        _saving = true;
        _status = null;
        try
        {
            var applied = await Api.UpdateSettingsAsync(new WeirSystemSettings
            {
                MaxRows = _maxRows,
                RequestTimeoutSeconds = _requestTimeoutSeconds,
                MaxTvpRows = _maxTvpRows,
                DefaultApiKeyRateLimitPerMinute = _defaultRateLimit,
                ApiKeyFailureThreshold = _apiKeyFailureThreshold,
                AuditRetentionDays = _auditRetentionDays,
                MaxConcurrentRequestsPerConnection = _maxConcurrentPerConnection,
                CircuitBreakerFailureThreshold = _circuitBreakerThreshold,
                CircuitBreakerResetSeconds = _circuitBreakerResetSeconds,
                RequestLogEnabled = _requestLogEnabled,
                SlowRequestThresholdPercent = _slowThresholdPercent,
                RequestLogRetentionDays = _requestLogRetentionDays,
                ResponseCacheMaxBytes = _responseCacheMaxBytes,
                ResponseDeliveryMode = _responseDeliveryMode,
                ResponseFlushBytes = _responseFlushBytes,
                ResponseCompressionMode = _responseCompressionMode,
            });

            if (applied is null)
            {
                _status = AdminStrings.Settings_UpdateRejected;
                _statusError = true;
            }
            else
            {
                _status = AdminStrings.Settings_SavedAndApplied;
                _statusError = false;
            }
        }
        catch (HttpRequestException)
        {
            _status = AdminStrings.Settings_SettingsServiceUnavailable;
            _statusError = true;
        }
        finally
        {
            _saving = false;
        }
    }

    // The runtime allocates arrays of 85000 bytes and up on the large-object heap. A flush threshold at
    // or above it puts the JSON writer's buffer there on every call, which is the cost the flushing is
    // there to avoid - so the field warns rather than silently undoing itself.
    private const int LargeObjectHeapThresholdBytes = 85_000;

    // Below roughly a kilobyte most rows are large enough to cross the threshold on their own, so the
    // batching the threshold exists for stops happening and each row costs a write.
    private const int MinSensibleFlushBytes = 1024;

    private static string DeliveryModeLabel(ResponseDeliveryMode mode) => mode switch
    {
        ResponseDeliveryMode.Auto => AdminStrings.Settings_DeliveryModeAuto,
        ResponseDeliveryMode.Stream => AdminStrings.Settings_DeliveryModeStream,
        ResponseDeliveryMode.Full => AdminStrings.Settings_DeliveryModeFull,
        _ => mode.ToString(),
    };

    private static string CompressionModeLabel(ResponseCompressionMode mode) => mode switch
    {
        ResponseCompressionMode.Auto => AdminStrings.Settings_CompressionModeAuto,
        ResponseCompressionMode.On => AdminStrings.Settings_CompressionModeOn,
        ResponseCompressionMode.Off => AdminStrings.Settings_CompressionModeOff,
        _ => mode.ToString(),
    };
}
