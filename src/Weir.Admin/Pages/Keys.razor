@page "/keys"
@attribute [Authorize]
@inherits LocalizedPage
@inject WeirApiClient Api
@inject IFlareClipboard Clipboard
@inject IDialogService Dialog

<FlareStack Gap="FlareSpacing.Medium">
    <PageHeader Title="@AdminStrings.Keys_PageTitle" Description="@AdminStrings.Keys_PageDescription">
        <Actions>
            <FlareButton Variant="ButtonVariant.Filled" Color="FlareColor.Primary" Size="ButtonSize.Sm" OnClick="OpenCreate">@AdminStrings.Keys_CreateKey</FlareButton>
        </Actions>
    </PageHeader>

    @if (_created is not null)
    {
        <FlareAlert Severity="AlertSeverity.Success" Title="@AdminStrings.Keys_CreatedAlertTitle">
            <FlareStack Gap="FlareSpacing.Small">
                <FlareText Typo="TypographyScale.BodySmall" Color="FlareColor.OnSurfaceVariant">@AdminStrings.Keys_CreatedAlertBody</FlareText>
                <FlareStack Row Align="FlareAlignItems.Center" Gap="FlareSpacing.Small" Wrap="true">
                    <FlareCode>@_created.PlainTextKey</FlareCode>
                    <FlareButton Variant="ButtonVariant.Filled" Color="FlareColor.Primary" Size="ButtonSize.Sm" OnClick="() => CopyAsync(_created.PlainTextKey)">@(_copied ? AdminStrings.Keys_Copied : AdminStrings.Common_Copy)</FlareButton>
                    <FlareButton Variant="ButtonVariant.Text" Size="ButtonSize.Sm" OnClick="() => { _created = null; _copied = false; }">@AdminStrings.Keys_Done</FlareButton>
                </FlareStack>
            </FlareStack>
        </FlareAlert>
    }

    @if (_error is not null)
    {
        <FlareAlert Severity="AlertSeverity.Error" Title="@AdminStrings.Common_ActionFailed">@_error</FlareAlert>
    }

    @if (_keys is null)
    {
        <FlareText Color="FlareColor.OnSurfaceVariant">@AdminStrings.Common_Loading</FlareText>
    }
    else if (_keys.Count == 0)
    {
        <FlareEmptyState Title="@AdminStrings.Keys_EmptyTitle" Description="@AdminStrings.Keys_EmptyDescription">
            <Icon><FlareIconView Value="@MaterialDesign3Icons.Regular.Key" /></Icon>
        </FlareEmptyState>
    }
    else
    {
        <FlareDataGrid Items="@_keys" Dense="true" Striped="true" Hoverable="true">
            <Columns>
                <FlareColumn TItem="ApiKeyInfo" Id="name" Title="@AdminStrings.Common_Name" Field="@(k => (object?)k.Name)" Sortable="true" Filterable="true" />
                <FlareColumn TItem="ApiKeyInfo" Id="key" Title="@AdminStrings.Keys_ColumnKey">
                    <Template><FlareText Element="span" Mono="true" Color="FlareColor.OnSurfaceVariant">@context.Prefix</FlareText></Template>
                </FlareColumn>
                <FlareColumn TItem="ApiKeyInfo" Id="scopes" Title="@AdminStrings.Keys_Scopes">
                    <Template><FlareText Element="span" Mono="true" Color="FlareColor.Primary">@string.Join(", ", context.Scopes)</FlareText></Template>
                </FlareColumn>
                <FlareColumn TItem="ApiKeyInfo" Id="procedure-access" Title="@AdminStrings.Keys_ProcedureAccess" Field="@(k => (object?)GrantsSummary(k.Grants))" Filterable="true" />
                <FlareColumn TItem="ApiKeyInfo" Id="created" Title="@AdminStrings.Keys_ColumnCreated" Field="@(k => (object?)k.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd"))" Sortable="true" />
                <FlareColumn TItem="ApiKeyInfo" Id="last-used" Title="@AdminStrings.Keys_ColumnLastUsed" Field="@(k => (object?)(k.LastUsedAt.HasValue ? k.LastUsedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "-"))" Sortable="true" />
                <FlareColumn TItem="ApiKeyInfo" Id="status" Title="@AdminStrings.Keys_ColumnStatus">
                    <Template><FlareChip Size="ChipSize.Sm" Variant="ChipVariant.Filled" Color="@(context.Enabled ? FlareColor.Success : FlareColor.Default)" Label="@(context.Enabled ? AdminStrings.Keys_StatusActive : AdminStrings.Keys_StatusRevoked)" /></Template>
                </FlareColumn>
                <FlareColumn TItem="ApiKeyInfo" Id="actions" Title="" Align="ColumnAlign.End">
                    <Template>
                        @if (context.Enabled)
                        {
                            <FlareButton Variant="ButtonVariant.Text" Color="FlareColor.Error" Size="ButtonSize.Sm" OnClick="@(() => RevokeAsync(context))">@AdminStrings.Keys_Revoke</FlareButton>
                        }
                    </Template>
                </FlareColumn>
            </Columns>
        </FlareDataGrid>
    }
</FlareStack>

<FlareDialog @bind-Visible="_showCreate" Title="@AdminStrings.Keys_CreateDialogTitle" Size="DialogSize.Md" ShowCloseButton="true" BeforeClose="ConfirmDiscardAsync">
    <ChildContent>
        <FlareStack Gap="FlareSpacing.Medium">
            @if (_createError is not null)
            {
                <FlareAlert Severity="AlertSeverity.Error" Title="@AdminStrings.Common_ActionFailed">@_createError</FlareAlert>
            }
            <FlareField Label="@AdminStrings.Common_Name" @bind-Value="_newName" Placeholder="@AdminStrings.Keys_NamePlaceholder" />
            <div>
                <FlareText Typo="TypographyScale.LabelMedium" Color="FlareColor.OnSurfaceVariant">@AdminStrings.Keys_Scopes</FlareText>
                @if (_scopes is null || _scopes.Count == 0)
                {
                    <FlareText Typo="TypographyScale.BodySmall" Color="FlareColor.OnSurfaceVariant">@AdminStrings.Keys_NoScopesDefined</FlareText>
                }
                else
                {
                    <FlareStack Row Wrap="true" Gap="FlareSpacing.Small">
                        @foreach (var scope in _scopes)
                        {
                            var selected = _selectedScopes.Contains(scope.Name);
                            <FlareChip Size="ChipSize.Sm" Label="@scope.Name"
                                       Variant="@(selected ? ChipVariant.Filled : ChipVariant.Outlined)"
                                       Color="@(selected ? FlareColor.Primary : FlareColor.Default)"
                                       OnClick="@(() => ToggleScope(scope.Name, !selected))" />
                        }
                    </FlareStack>
                }
            </div>
            <div>
                <FlareText Typo="TypographyScale.LabelMedium" Color="FlareColor.OnSurfaceVariant">@AdminStrings.Keys_ProcedureAccess</FlareText>
                <FlareText Typo="TypographyScale.BodySmall" Color="FlareColor.OnSurfaceVariant">@AdminStrings.Keys_ProcedureAccessHelp</FlareText>
                <FlareStack Gap="FlareSpacing.XSmall" Style="margin-top:.5rem;">
                    @foreach (var grant in _grants)
                    {
                        <FlareStack Row Align="FlareAlignItems.Center" Gap="FlareSpacing.Small">
                            <FlareSelect TValue="string" @bind-Value="grant.Connection" Items="@GrantConnectionOptions" />
                            <FlareField TValue="string" @bind-Value="grant.Schema" Placeholder="@AdminStrings.Keys_SchemaPlaceholder" />
                            <FlareField TValue="string" @bind-Value="grant.ObjectName" Placeholder="@AdminStrings.Keys_ObjectPlaceholder" />
                            <FlareButton Variant="ButtonVariant.Text" Color="FlareColor.Error" Size="ButtonSize.Sm" OnClick="@(() => _grants.Remove(grant))">@AdminStrings.Common_Remove</FlareButton>
                        </FlareStack>
                    }
                    <FlareStack Row><FlareButton Variant="ButtonVariant.Text" Size="ButtonSize.Sm" OnClick="AddGrant">@AdminStrings.Keys_AddGrant</FlareButton></FlareStack>
                </FlareStack>
            </div>
        </FlareStack>
    </ChildContent>
    <Actions>
        <FlareButton Variant="ButtonVariant.Text" OnClick="() => _showCreate = false">@AdminStrings.Common_Cancel</FlareButton>
        <FlareButton Variant="ButtonVariant.Filled" Color="FlareColor.Primary" OnClick="CreateAsync" Loading="_busy">@AdminStrings.Keys_CreateKey</FlareButton>
    </Actions>
</FlareDialog>

@code {
    private List<ApiKeyInfo>? _keys;
    private List<Scope>? _scopes;
    private List<ConnectionInfo>? _connections;
    private readonly HashSet<string> _selectedScopes = new(StringComparer.Ordinal);
    private readonly List<GrantEdit> _grants = [];
    private bool _showCreate;
    private bool _busy;
    private bool _copied;
    private string _newName = string.Empty;
    private ApiKeyCreated? _created;
    private string? _error;
    private string? _createError;

    /// <summary>Loads keys, the available scopes and connections.</summary>
    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _scopes = await Api.GetScopesAsync();
        _connections = await Api.GetConnectionsAsync();
    }

    /// <summary>Connection options for a grant selector: the "any" wildcard plus every known connection.</summary>
    private IEnumerable<string> GrantConnectionOptions => new[] { "*" }.Concat(_connections?.Select(c => c.Name) ?? []);

    /// <summary>Opens the create-key modal with a fresh form.</summary>
    private void OpenCreate()
    {
        _newName = string.Empty;
        _selectedScopes.Clear();
        _grants.Clear();
        _createError = null;
        _showCreate = true;
    }

    /// <summary>Copies the plaintext key to the clipboard via Flare's clipboard service.</summary>
    /// <param name="key">The plaintext key.</param>
    private async Task CopyAsync(string key)
    {
        await Clipboard.CopyAsync(key);
        _copied = true;
    }

    /// <summary>Adds an empty grant row (defaults to allow-any).</summary>
    private void AddGrant() => _grants.Add(new GrantEdit());

    /// <summary>Builds a short summary of a key's grants for the list.</summary>
    private static string GrantsSummary(IReadOnlyList<ApiKeyGrant> grants) =>
        grants.Count == 0
            ? AdminStrings.Keys_GrantsAll
            : string.Join(", ", grants.Select(g => $"{g.Connection}/{g.Schema}/{g.ObjectName}"));

    /// <summary>Reloads the key list.</summary>
    private async Task LoadAsync() => _keys = await Api.GetKeysAsync();

    /// <summary>Toggles a scope selection for the new key.</summary>
    private void ToggleScope(string name, bool on)
    {
        if (on)
        {
            _selectedScopes.Add(name);
        }
        else
        {
            _selectedScopes.Remove(name);
        }
    }

    /// <summary>Creates a key and captures its plaintext for one-time display.</summary>
    private async Task CreateAsync()
    {
        if (string.IsNullOrWhiteSpace(_newName))
        {
            return;
        }

        _busy = true;
        _createError = null;
        try
        {
            _created = await Api.CreateKeyAsync(new ApiKeyCreate
            {
                Name = _newName,
                Scopes = _selectedScopes.ToList(),
                Grants = _grants.Select(g => g.ToGrant()).ToList(),
            });
        }
        catch (WeirApiException ex)
        {
            // Keep the dialog open with its content, so the failure can be corrected and retried.
            _createError = ex.Message;
            return;
        }
        finally
        {
            _busy = false;
        }

        _copied = false;
        _showCreate = false;
        _newName = string.Empty;
        _selectedScopes.Clear();
        _grants.Clear();
        await LoadAsync();
    }

    /// <summary>Whether the create-key form has any content worth confirming before discarding.</summary>
    /// <returns>True if a name, scope or grant has been entered.</returns>
    private bool FormHasContent() =>
        !string.IsNullOrWhiteSpace(_newName) || _selectedScopes.Count > 0 || _grants.Count > 0;

    /// <summary>
    /// Guards accidental dismissal (Escape / scrim / close button) of a partially-filled create form;
    /// the Cancel and Create buttons close the dialog directly and are not routed through this guard.
    /// </summary>
    /// <param name="reason">Why the dialog is closing.</param>
    /// <returns>True to allow the close, false to keep the dialog open.</returns>
    private async ValueTask<bool> ConfirmDiscardAsync(DialogCloseReason reason)
    {
        if (!FormHasContent())
        {
            return true;
        }

        var confirmed = await Dialog.ConfirmAsync(
            AdminStrings.Keys_DiscardTitle, AdminStrings.Keys_DiscardBody, AdminStrings.Keys_DiscardConfirm, AdminStrings.Keys_DiscardCancel);
        return confirmed == true;
    }

    /// <summary>Confirms, then revokes a key and reloads. Revoking immediately breaks any caller using it.</summary>
    /// <param name="key">The key to revoke.</param>
    private async Task RevokeAsync(ApiKeyInfo key)
    {
        var confirmed = await Dialog.ConfirmAsync(
            AdminStrings.Keys_RevokeTitle,
            string.Format(AdminStrings.Keys_RevokeBody, key.Name),
            AdminStrings.Keys_Revoke, AdminStrings.Common_Cancel);
        if (confirmed != true)
        {
            return;
        }

        _error = null;
        try
        {
            await Api.RevokeKeyAsync(key.Id);
        }
        catch (WeirApiException ex)
        {
            _error = ex.Message;
            return;
        }

        await LoadAsync();
    }

    /// <summary>Mutable editor model for one resource grant.</summary>
    private sealed class GrantEdit
    {
        /// <summary>Connection pattern (server + database), or blank / <c>*</c> for any.</summary>
        public string Connection { get; set; } = "*";

        /// <summary>Schema pattern, or blank / <c>*</c> for any.</summary>
        public string Schema { get; set; } = "*";

        /// <summary>Object pattern, or blank / <c>*</c> for any.</summary>
        public string ObjectName { get; set; } = "*";

        /// <summary>Converts to a contract grant, treating blank fields as the "any" wildcard.</summary>
        /// <returns>The resource grant.</returns>
        public ApiKeyGrant ToGrant() => new()
        {
            Connection = Normalize(Connection),
            Schema = Normalize(Schema),
            ObjectName = Normalize(ObjectName),
        };

        /// <summary>Maps a blank value to the wildcard and trims otherwise.</summary>
        private static string Normalize(string value) =>
            string.IsNullOrWhiteSpace(value) ? "*" : value.Trim();
    }
}
