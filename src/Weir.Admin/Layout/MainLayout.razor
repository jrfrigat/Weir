@inherits LayoutComponentBase
@implements IDisposable
@inject TokenStore Tokens
@inject WeirAuthStateProvider Auth
@inject WeirApiClient Api
@inject NavigationManager Navigation
@inject LanguageService Lang

@* Command Center shell, composed from Flare: a top app bar with route tabs over a scrolling content
   region. A single fixed theme (Visual Studio 2026 geometry, Command Center palette) - no switcher.
   The signed-in user's name on the right is a menu: Account / Sign out. *@
<FlareLayout>
    @* Match the Command Center design's 50px nav bar. Flare 0.1.9 makes the height a first-class param and
       gives the bar a bottom border by default; the only thing left is lifting its surface above the canvas,
       via the dedicated --flare-layout-appbar-bg token. *@
    <FlareLayoutAppBar Height="50px" Style="--flare-layout-appbar-bg:var(--flare-color-surface-container-low);">
        <FlareStack Row Align="FlareAlignItems.Center" Gap="FlareSpacing.Medium" Style="width:100%;min-width:0;">
            <FlareStack Row Align="FlareAlignItems.Center" Gap="FlareSpacing.XSmall">
                <WeirMark Size="1.6rem" />
                <FlareText Typo="TypographyScale.TitleMedium" Weight="FontWeight.Bold" Mono="true">weir</FlareText>
            </FlareStack>
            <FlareLinkTabs>
                <FlareLinkTab Href="/" Match="NavMatchMode.Exact" Label="@AdminStrings.Nav_Overview" />
                <FlareLinkTab Href="/endpoints" Label="@AdminStrings.Nav_Endpoints" />
                <FlareLinkTab Href="/scopes" Label="@AdminStrings.Nav_Scopes" />
                <FlareLinkTab Href="/keys" Label="@AdminStrings.Nav_Keys" />
                <FlareLinkTab Href="/admins" Label="@AdminStrings.Nav_Admins" />
                <FlareLinkTab Href="/logs" Label="@AdminStrings.Nav_Logs" />
                <FlareLinkTab Href="/audit" Label="@AdminStrings.Nav_Audit" />
                <FlareLinkTab Href="/settings" Label="@AdminStrings.Nav_Settings" />
            </FlareLinkTabs>
            <FlareSpacer />
            @* UI language picker, then the source-repository link, then the account menu. *@
            <LanguageSwitcher />
            <FlareIconButton Href="https://github.com/jrfrigat/weir" Target="_blank"
                             AriaLabel="@AdminStrings.Layout_GitHubAriaLabel" Size="ButtonSize.Sm">
                <GitHubIcon Size="1.15rem" />
            </FlareIconButton>
            <AuthorizeView>
                <Authorized>
                    <FlareMenu Anchor="MenuAnchor.BottomRight" AriaLabel="@AdminStrings.Layout_AccountMenuAriaLabel">
                        <Activator>
                            <FlareButton Variant="ButtonVariant.Text" Size="ButtonSize.Sm">
                                <ChildContent>@context.User.Identity?.Name</ChildContent>
                                <TrailingIcon><FlareIcon Name="expand_more" Size="1.05rem" /></TrailingIcon>
                            </FlareButton>
                        </Activator>
                        <ChildContent>
                            <FlareMenuItem Icon="account_circle" Href="/account">@AdminStrings.Layout_Account</FlareMenuItem>
                            <FlareMenuItem Icon="logout" OnClick="LogoutAsync">@AdminStrings.Layout_SignOut</FlareMenuItem>
                        </ChildContent>
                    </FlareMenu>
                </Authorized>
            </AuthorizeView>
        </FlareStack>
    </FlareLayoutAppBar>
    <FlareLayoutContent>
        <ErrorBoundary @ref="_errorBoundary">
            <ChildContent>@Body</ChildContent>
            <ErrorContent>
                <FlareAlert Severity="AlertSeverity.Error" Title="@AdminStrings.Layout_ErrorTitle">
                    @AdminStrings.Layout_ErrorBody
                </FlareAlert>
            </ErrorContent>
        </ErrorBoundary>
    </FlareLayoutContent>
</FlareLayout>

@code {
    private ErrorBoundary? _errorBoundary;

    /// <summary>
    /// Recovers the error boundary on navigation so a per-page error clears when the user leaves it,
    /// and follows the UI language. A layout derives from LayoutComponentBase, so it cannot inherit
    /// LocalizedPage and subscribes to the language directly.
    /// </summary>
    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
        Lang.LanguageChanged += OnLanguageChanged;
    }

    /// <summary>Handles route changes by clearing any caught error.</summary>
    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e) =>
        _errorBoundary?.Recover();

    /// <summary>Re-renders the shell (nav labels, account menu) after a language switch.</summary>
    private void OnLanguageChanged() => _ = InvokeAsync(StateHasChanged);

    /// <summary>Revokes the refresh token, clears both tokens, resets auth state and returns to login.</summary>
    private async Task LogoutAsync()
    {
        var refreshToken = await Tokens.GetRefreshAsync();
        await Api.LogoutAsync(refreshToken);
        await Tokens.ClearAllAsync();
        Auth.NotifyLogout();
        Navigation.NavigateTo("login");
    }

    /// <summary>Unsubscribes from navigation and language events.</summary>
    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        Lang.LanguageChanged -= OnLanguageChanged;
    }
}
